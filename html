    /* GROUPS */
    function createGroups(){
      state.groups = [];
      state.knockoutTree = null;
      const groupCount = Math.max(1, Math.min(state.groupCount || 1, state.teams.length || 1));
      for(let i = 0; i < groupCount; i++) state.groups.push([]);

      const sorted = getSortedTeamsBySeed().map(t => ({
        id:t.id,
        name:t.name,
        seed:t.seed,
        played:0,
        points:0,
        gf:0,
        ga:0
      }));

      const baseSize = Math.floor(sorted.length / groupCount);
      const remainder = sorted.length % groupCount;
      let cursor = 0;

      for(let g = 0; g < groupCount; g++){
        const thisSize = baseSize + (g < remainder ? 1 : 0);
        state.groups[g] = sorted.slice(cursor, cursor + thisSize);
        cursor += thisSize;
      }

      renderGroups();
      renderBracketEmpty();
    }

