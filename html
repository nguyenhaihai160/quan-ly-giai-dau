      }];

      const contentRows = (state.tournamentContents || []).map((item, i) => ({ STT:i + 1, NoiDung:item.name, NhomTuoi:item.ageGroup, TheThuc:getFormatText(item.format || 'knockout'), TrangThai:getContentStatusText(item.status || 'draft'), SoVDV:item.data?.teams?.length || 0, SoTran:item.data?.schedule?.length || 0, GhiChu:item.note || '' }));
      const teamRows = state.teams.map((t, i) => ({ STT:i + 1, Seed:t.seed, Ten:t.name }));
      const resultRows = Object.keys(state.results).map(key => ({ Tran:key, DiemA:state.results[key].a, DiemB:state.results[key].b, TheVangA:state.results[key].yellowA ?? '', TheVangB:state.results[key].yellowB ?? '', TheDoA:state.results[key].redA ?? '', TheDoB:state.results[key].redB ?? '' }));
      const scheduleRows = state.schedule.map((m, i) => ({
        STT:i + 1,
        MaTran:m.matchCode || '',
        GiaiDoan:m.phase,
        BatDau:formatVNDateTime(new Date(m.start)),
        KetThuc:formatVNDateTime(new Date(m.end)),
        BanSan:m.court,
        CapDau:`${m.teamA} vs ${m.teamB}`,
        TrangThai:getStatusText(getMatchStatus(m))
      }));
      const standingsRows = state.format === 'knockout'
        ? buildKnockoutFinalRows().map((row, i) => ({ STT:i + 1, Hang:row.rank, DanhHieu:row.title, DoiVDV:row.teamName, GhiChu:row.note }))
        : (state.groups || []).flatMap((group, g) => getSortedGroupStandings(g).map((team, i) => ({ Bang:String.fromCharCode(65 + g), Hang:i + 1, DoiVDV:team.name, Diem:team.points, HieuSo:team.gf - team.ga, TheVang:team.yellowCards || 0, TheDo:team.redCards || 0, FairPlay:getTeamFairPlayPenalty(team) })));

      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(infoRows), 'ThongTinGiai');
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(contentRows), 'NoiDungGiai');
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(teamRows), 'Teams');
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(resultRows), 'Results');
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(scheduleRows), 'Schedule');
      XLSX.utils.book_append_sheet(wb, XLSX.utils.json_to_sheet(standingsRows), 'Standings');
