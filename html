    function getSeededLiveScore(match){
      if(!match) return { a:'0', b:'0' };
      if(state.format === 'groups'){
        const rs = findGroupResultByMatch(match) || {};
        return {
          a: Number.isFinite(Number(rs.a)) ? String(Number(rs.a)) : '0',
          b: Number.isFinite(Number(rs.b)) ? String(Number(rs.b)) : '0'
        };
      }
      const rs = state.results?.[`ko_${match.matchId}`] || {};
      const a = Number.isFinite(Number(rs.a)) ? Number(rs.a) : (Number.isFinite(Number(match?.scoreA)) ? Number(match.scoreA) : 0);
      const b = Number.isFinite(Number(rs.b)) ? Number(rs.b) : (Number.isFinite(Number(match?.scoreB)) ? Number(match.scoreB) : 0);
      return { a:String(a), b:String(b) };
