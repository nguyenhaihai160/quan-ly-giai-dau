    function beginLiveOverlayDrag(clientX, clientY){
      const overlay = document.getElementById('liveScoreOverlay');
      const live = { ...defaultLivestreamState(), ...(state.livestream || {}) };
      if(!overlay || live.showScoreboard === false) return;
      liveOverlayDragState.active = true;
      liveOverlayDragState.startX = clientX;
      liveOverlayDragState.startY = clientY;
      liveOverlayDragState.originX = Number(live.overlayX) || 0;
      liveOverlayDragState.originY = Number(live.overlayY) || 0;
      liveOverlayDragState.currentX = liveOverlayDragState.originX;
      liveOverlayDragState.currentY = liveOverlayDragState.originY;
      overlay.classList.add('dragging');
      document.body.classList.add('live-overlay-dragging');
    }

    function moveLiveOverlayDrag(clientX, clientY){
      if(!liveOverlayDragState.active) return;
      const dx = clientX - liveOverlayDragState.startX;
      const dy = clientY - liveOverlayDragState.startY;
      const pos = setLiveOverlayPosition(liveOverlayDragState.originX + dx, liveOverlayDragState.originY + dy, { persist:false });
      liveOverlayDragState.currentX = pos.x;
      liveOverlayDragState.currentY = pos.y;
    }

    function endLiveOverlayDrag(){
      if(!liveOverlayDragState.active) return;
      liveOverlayDragState.active = false;
      document.getElementById('liveScoreOverlay')?.classList.remove('dragging');
      document.body.classList.remove('live-overlay-dragging');
      setLiveOverlayPosition(liveOverlayDragState.currentX, liveOverlayDragState.currentY, { persist:true });
      renderLivestreamSummary();
    }

    function setupLiveOverlayDrag(){
      const handle = document.getElementById('liveScoreDragHandle');
      if(!handle || handle.dataset.bound === '1') return;
      handle.dataset.bound = '1';
      handle.addEventListener('mousedown', event => {
        if(event.button !== 0) return;
        event.preventDefault();
        beginLiveOverlayDrag(event.clientX, event.clientY);
      });
      handle.addEventListener('touchstart', event => {
        const touch = event.touches?.[0];
        if(!touch) return;
        event.preventDefault();
        beginLiveOverlayDrag(touch.clientX, touch.clientY);
      }, { passive:false });
      document.addEventListener('mousemove', event => moveLiveOverlayDrag(event.clientX, event.clientY));
      document.addEventListener('mouseup', endLiveOverlayDrag);
      document.addEventListener('touchmove', event => {
        const touch = event.touches?.[0];
        if(!touch) return;
        moveLiveOverlayDrag(touch.clientX, touch.clientY);
      }, { passive:false });
      document.addEventListener('touchend', endLiveOverlayDrag);
      document.addEventListener('touchcancel', endLiveOverlayDrag);
    }

    function getLiveTimerSnapshot(){
      const live = { ...defaultLivestreamState(), ...(state.livestream || {}) };
      const mode = live.timerMode === 'countdown' ? 'countdown' : 'countup';
      const total = parsePositiveInt(live.timerTotalSeconds, 0);
      const baseElapsed = parsePositiveInt(live.timerElapsed, 0);
      const runningDelta = live.timerRunning && live.timerStartedAt ? Math.max(0, Math.floor((Date.now() - Number(live.timerStartedAt)) / 1000)) : 0;
      const elapsed = baseElapsed + runningDelta;
      const displaySeconds = mode === 'countdown' ? Math.max(0, total - elapsed) : elapsed;
      const expired = mode === 'countdown' && total > 0 && elapsed >= total;
      return { mode, total, elapsed, displaySeconds, expired, running: !!live.timerRunning };
    }

    function formatClockSeconds(totalSeconds){
      const total = Math.max(0, parsePositiveInt(totalSeconds, 0));
      const hours = Math.floor(total / 3600);
      const minutes = Math.floor((total % 3600) / 60);
      const seconds = total % 60;
      const pad = n => String(n).padStart(2, '0');
      return hours > 0 ? `${pad(hours)}:${pad(minutes)}:${pad(seconds)}` : `${pad(minutes)}:${pad(seconds)}`;
    }

