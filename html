    function syncLiveTimerFromSchedule(){
      saveLivestreamSettings(true);
      const match = getLiveMatchObject();
      if(!match){
        alert('Hãy chọn trận đấu trước khi đồng bộ đồng hồ.');
        return;
      }
      const start = new Date(match.start).getTime();
      const end = new Date(match.end).getTime();
      const live = { ...defaultLivestreamState(), ...(state.livestream || {}) };
      if(Number.isFinite(start) && Number.isFinite(end) && end > start){
        const now = Date.now();
        const elapsed = Math.max(0, Math.floor((now - start) / 1000));
        live.timerTotalSeconds = Math.max(0, Math.floor((end - start) / 1000));
        if(live.timerMode === 'countdown'){
          live.timerElapsed = elapsed;
        }else{
          live.timerElapsed = elapsed;
        }
        live.timerStartedAt = 0;
        live.timerRunning = false;
        state.livestream = live;
        saveState();
        renderLivestreamSummary();
      }else{
        alert('Trận này chưa có giờ bắt đầu/kết thúc hợp lệ để đồng bộ.');
      }
    }

    function selectRecorderMimeType(){
      if(typeof MediaRecorder === 'undefined') return '';
      const options = ['video/webm;codecs=vp9,opus', 'video/webm;codecs=vp8,opus', 'video/webm', 'video/mp4'];
      return options.find(item => MediaRecorder.isTypeSupported && MediaRecorder.isTypeSupported(item)) || '';
    }

    function renderLiveReplayList(){
      const list = document.getElementById('liveReplayList');
      const status = document.getElementById('liveReplayStatus');
      if(status){
        if(liveReplayState.isRecording){
          status.textContent = 'Đang ghi clip để xem lại tình huống...';
        }else if(liveReplayState.clips.length){
          status.textContent = `Đã có ${liveReplayState.clips.length} clip replay trong phiên này.`;
        }else{
          status.textContent = liveMediaState.stream ? 'Sẵn sàng ghi replay từ nguồn hình hiện tại.' : 'Replay đang chờ nguồn hình.';
        }
      }
      if(!list) return;
      if(!liveReplayState.clips.length){
        list.innerHTML = '<div class="mini-list-item"><div class="mini-list-title">Chưa có clip replay</div><div class="mini-list-sub">Bấm Bắt đầu ghi clip rồi dừng khi kết thúc tình huống để xem lại ngay trên máy điều hành.</div></div>';
        return;
      }
      list.innerHTML = liveReplayState.clips.map((clip, index) => `
        <div class="live-replay-item">
          <div>
            <div class="live-replay-item-title">${escapeHtml(clip.title)}</div>
            <div class="live-replay-item-sub">${escapeHtml(clip.meta)}</div>
          </div>
          <div class="live-replay-item-actions">
            <button class="btn-blue" onclick="playReplayClip(${index})">Xem</button>
            <button class="btn-gray" onclick="removeReplayClip(${index})">Xóa</button>
          </div>
        </div>`).join('');
      }

    function startReplayCapture(){
      if(!liveMediaState.stream){
        alert('Hãy kết nối camera hoặc chia sẻ màn hình trước khi ghi replay.');
        return;
      }
      if(typeof MediaRecorder === 'undefined'){
        alert('Trình duyệt hiện tại không hỗ trợ ghi clip replay.');
        return;
      }
      if(liveReplayState.isRecording) return;
      try{
        liveReplayState.chunks = [];
        const mimeType = selectRecorderMimeType();
        const recorder = mimeType ? new MediaRecorder(liveMediaState.stream, { mimeType }) : new MediaRecorder(liveMediaState.stream);
        recorder.ondataavailable = event => {
          if(event.data && event.data.size > 0) liveReplayState.chunks.push(event.data);
        };
        recorder.onstop = () => {
          liveReplayState.isRecording = false;
          const type = recorder.mimeType || 'video/webm';
          if(!liveReplayState.chunks.length){
            renderLiveReplayList();
            return;
          }
          const blob = new Blob(liveReplayState.chunks, { type });
          const url = URL.createObjectURL(blob);
          const match = getLiveMatchObject();
          const title = match ? `Replay • ${match.teamA || 'Đội A'} vs ${match.teamB || 'Đội B'}` : 'Replay clip';
          const meta = `${formatVNDateTime(new Date())} • ${Math.round(blob.size / 1024)} KB`;
          liveReplayState.clips.unshift({ url, title, meta });
          liveReplayState.clips = liveReplayState.clips.slice(0, 8);
          renderLiveReplayList();
          playReplayClip(0);
          updateLiveCameraStatus('Đã lưu clip replay để xem lại tình huống.', 'ok');
        };
        recorder.start();
        liveReplayState.recorder = recorder;
        liveReplayState.isRecording = true;
        renderLiveReplayList();
        updateLiveCameraStatus('Đang ghi clip replay từ nguồn live.', 'ok');
      }catch(err){
        console.error(err);
        alert('Không thể bắt đầu ghi replay trên trình duyệt này.');
      }
    }

    function stopReplayCapture(){
      if(liveReplayState.recorder && liveReplayState.isRecording){
        liveReplayState.recorder.stop();
      }
    }

    function playReplayClip(index){
