        return { key, label, match };
      });
    }

    function refreshLivestreamMatchOptions(){
      const select = document.getElementById('liveMatchSelect');
      if(!select) return;
      const options = getLivestreamMatchOptions();
      const currentValue = state.livestream?.currentMatchKey || '';
      if(!options.length){
        select.innerHTML = '<option value="">Chưa có lịch thi đấu</option>';
        select.value = '';
        return;
      }
      select.innerHTML = '<option value="">-- Chọn trận đấu --</option>' + options.map(item => `<option value="${escapeHtml(item.key)}">${escapeHtml(item.label)}</option>`).join('');
