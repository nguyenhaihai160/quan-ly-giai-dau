    async function shareLivestreamPackage(platform){
      saveLivestreamSettings(true);
      const live = state.livestream || {};
      const match = getLiveMatchObject();
      const chosenPlatform = platform || live.currentPlatform || 'facebook';
      const url = readPlatformUrl(chosenPlatform) || window.location.href;
      const payload = [
        live.title || buildDefaultLiveTitle(match),
        match ? `${match.phase || 'Trận đấu'} • ${match.teamA || 'Chờ đội A'} vs ${match.teamB || 'Chờ đội B'}` : '',
        live.note || ''
      ].filter(Boolean).join('\n');

      if(navigator.share){
        try{
          await navigator.share({ title: live.title || 'Livestream trận đấu', text: payload, url });
          return;
        }catch(err){
          // fallback below
        }
      }

      try{
        await navigator.clipboard.writeText(`${payload}
${url}`.trim());
      }catch(err){
        console.warn('Không copy được nội dung chia sẻ', err);
      }

      if(chosenPlatform === 'facebook' && url){
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}&quote=${encodeURIComponent(payload)}`, '_blank');
      }else if(url){
        window.open(url, '_blank');
      }
      alert('Đã chuẩn bị nội dung chia sẻ và mở nền tảng tương ứng.');
