    function removeReplayClip(index){
      const clip = liveReplayState.clips[index];
      if(!clip) return;
      try{ URL.revokeObjectURL(clip.url); }catch(e){}
      liveReplayState.clips.splice(index, 1);
      const player = document.getElementById('liveReplayPlayer');
      if(player && player.src === clip.url) player.removeAttribute('src');
      renderLiveReplayList();
    }

