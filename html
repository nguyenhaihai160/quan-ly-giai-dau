<script>
(function(){
  const PUBLIC_PORTAL_TAB_ID = 'tabPortalPublic';

  function portalEscapeHtml(value){
    if(typeof escapeHtml === 'function') return escapeHtml(value == null ? '' : String(value));
    return String(value == null ? '' : value)
      .replace(/&/g,'&amp;')
      .replace(/</g,'&lt;')
      .replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;')
      .replace(/'/g,'&#39;');
  }

  function portalEscapeAttr(value){
    if(typeof safeEscape === 'function') return safeEscape(value == null ? '' : String(value));
    return portalEscapeHtml(value);
  }

  function portalRemoveAdminBits(node){
    if(!node) return '';
    var clone = node.cloneNode(true);
    clone.querySelectorAll('button,input,select,textarea,script').forEach(function(el){ el.remove(); });
    clone.querySelectorAll('.toolbar,.toolbar-wrap,.field,.inline-field,.status-select-wrap,.schedule-score-edit,.schedule-datetime-edit,.schedule-card-edit,.schedule-group-note,.live-command-grid,.camera-control-grid,.live-platform-actions,.live-share-toolbar,.result-status,.live-fold-toggle').forEach(function(el){ el.remove(); });
    clone.querySelectorAll('*').forEach(function(el){
      Array.prototype.slice.call(el.attributes || []).forEach(function(attr){
        if(/^on/i.test(attr.name)) el.removeAttribute(attr.name);
      });
    });
    return clone.innerHTML;
  }

  function portalCollectEmbeddedStyles(){
    return Array.prototype.map.call(document.querySelectorAll('style'), function(styleTag){
      return styleTag.outerHTML;
    }).join('\n');
  }

  function portalGetCurrentMatch(){
    var live = Object.assign({}, (typeof defaultLivestreamState === 'function' ? defaultLivestreamState() : {}), (state && state.livestream) || {});
    var key = live.currentMatchKey || '';
    if(!key || !state || !Array.isArray(state.schedule)) return null;
    for(var i=0;i<state.schedule.length;i++){
      var match = state.schedule[i];
      if(typeof getScheduleMatchKey === 'function' && getScheduleMatchKey(match) === key) return match;
    }
    return null;
  }

  function portalGetLiveEmbed(url){
    var raw = String(url || '').trim();
    if(!raw) return '';
    try{
      var parsed = new URL(raw, window.location.href);
      if(parsed.hostname.indexOf('youtu.be') >= 0){
        var shortId = parsed.pathname.replace(/^\//,'').split('/')[0];
        return shortId ? ('https://www.youtube.com/embed/' + shortId) : '';
      }
      if(parsed.hostname.indexOf('youtube.com') >= 0){
        if(parsed.pathname.indexOf('/embed/') === 0) return parsed.href;
        if(parsed.pathname.indexOf('/watch') === 0){
          var id = parsed.searchParams.get('v');
          return id ? ('https://www.youtube.com/embed/' + id) : '';
        }
        if(parsed.pathname.indexOf('/live/') === 0){
          var liveId = parsed.pathname.split('/').filter(Boolean).pop();
          return liveId ? ('https://www.youtube.com/embed/' + liveId) : '';
        }
      }
    }catch(e){}
    return '';
  }

  function portalBuildIdentityBadge(type, value, fallback){
    if(type === 'logo' && value){
      return '<span class="portal-team-logo"><img src="' + portalEscapeAttr(value) + '" alt="logo"></span>';
    }
    if(type === 'flag' && value){
      return '<span class="portal-team-flag">' + portalEscapeHtml(value) + '</span>';
    }
    return '<span class="portal-team-fallback">' + portalEscapeHtml(fallback || '•') + '</span>';
  }

  function portalBuildSetLine(scoreView){
    var a = Array.isArray(scoreView && scoreView.setDetailsA) ? scoreView.setDetailsA : [];
    var b = Array.isArray(scoreView && scoreView.setDetailsB) ? scoreView.setDetailsB : [];
    var rows = [];
    for(var i=0;i<Math.max(a.length,b.length,0);i++){
      var av = a[i];
      var bv = b[i];
      if(av === '' && bv === '') continue;
      rows.push('<div class="portal-set-pill">Set ' + (i+1) + ': <strong>' + portalEscapeHtml(av === '' ? '-' : av) + '</strong> - <strong>' + portalEscapeHtml(bv === '' ? '-' : bv) + '</strong></div>');
    }
    return rows.join('');
  }

  function portalBuildLiveSection(){
    var live = Object.assign({}, (typeof defaultLivestreamState === 'function' ? defaultLivestreamState() : {}), (state && state.livestream) || {});
    var match = portalGetCurrentMatch();
    var scoreView = typeof getLiveScoreView === 'function' ? getLiveScoreView(match) : {
      teamA: match && match.teamA ? match.teamA : 'Đội / VĐV A',
      teamB: match && match.teamB ? match.teamB : 'Đội / VĐV B',
      scoreA: live.scoreA || '0',
      scoreB: live.scoreB || '0',
      setA: live.setA || '0',
      setB: live.setB || '0',
      segmentLabel: live.segmentLabel || 'Trận đấu',
      meta: live.scoreMeta || '',
      teamAFlag: live.teamAFlag || '',
      teamBFlag: live.teamBFlag || '',
      teamALogo: live.teamALogo || '',
      teamBLogo: live.teamBLogo || '',
      setDetailsA: live.setDetailsA || [],
      setDetailsB: live.setDetailsB || []
    };
    var matchStatus = match && typeof getMatchStatus === 'function' ? getMatchStatus(match) : (live.isLive ? 'live' : 'scheduled');
    var statusText = live.isLive ? 'Đang phát trực tiếp' : (typeof getStatusText === 'function' ? getStatusText(matchStatus) : 'Chưa phát');
    var platformLabel = typeof getLivePlatformLabel === 'function' ? getLivePlatformLabel(live.currentPlatform || 'facebook') : 'Nền tảng live';
    var title = portalEscapeHtml(live.title || (typeof buildDefaultLiveTitle === 'function' ? buildDefaultLiveTitle(match) : '') || 'Chưa có tiêu đề live');
    var note = portalEscapeHtml(live.note || 'Ban tổ chức có thể gắn trận đang phát và dán link xem trực tiếp ở trang quản lý.');
    var embedUrl = portalGetLiveEmbed(live.youtubeUrl || '');
    var setLine = portalBuildSetLine(scoreView);
    var scheduleMeta = match ? ((match.phase || 'Trận đấu') + ' • ' + (match.court || 'Chưa xếp sân') + ' • ' + (typeof formatVNDateTime === 'function' ? formatVNDateTime(new Date(match.start)) : '')) : 'Chưa gắn trận nào với trang live.';
    var liveButtons = [
      live.facebookUrl ? '<a class="portal-live-btn" href="' + portalEscapeAttr(live.facebookUrl) + '" target="_blank" rel="noopener">Facebook</a>' : '',
      live.youtubeUrl ? '<a class="portal-live-btn" href="' + portalEscapeAttr(live.youtubeUrl) + '" target="_blank" rel="noopener">YouTube</a>' : '',
      live.tiktokUrl ? '<a class="portal-live-btn" href="' + portalEscapeAttr(live.tiktokUrl) + '" target="_blank" rel="noopener">TikTok</a>' : ''
    ].filter(Boolean).join('');

    return '' +
      '<div class="portal-live-shell">' +
        '<div class="portal-live-head">' +
          '<div>' +
            '<div class="portal-eyebrow">LIVE STREAM</div>' +
            '<h3 class="portal-live-title">' + title + '</h3>' +
            '<div class="portal-live-sub">' + portalEscapeHtml(scheduleMeta) + '</div>' +
          '</div>' +
          '<div class="portal-live-status">' + portalEscapeHtml(statusText) + '<span>' + portalEscapeHtml(platformLabel) + '</span></div>' +
        '</div>' +
        '<div class="portal-score-slim">' +
          '<div class="portal-score-team is-left">' + portalBuildIdentityBadge('logo', scoreView.teamALogo, 'A') + portalBuildIdentityBadge('flag', scoreView.teamAFlag, 'A') + '<strong>' + portalEscapeHtml(scoreView.teamA || 'Đội A') + '</strong></div>' +
          '<div class="portal-score-core"><span class="portal-score-main">' + portalEscapeHtml(scoreView.scoreA || '0') + '</span><span class="portal-score-divider">-</span><span class="portal-score-main">' + portalEscapeHtml(scoreView.scoreB || '0') + '</span><span class="portal-score-meta">' + portalEscapeHtml(scoreView.segmentLabel || 'Live') + ' • Set ' + portalEscapeHtml(scoreView.setA || '0') + ' - ' + portalEscapeHtml(scoreView.setB || '0') + '</span></div>' +
          '<div class="portal-score-team is-right"><strong>' + portalEscapeHtml(scoreView.teamB || 'Đội B') + '</strong>' + portalBuildIdentityBadge('flag', scoreView.teamBFlag, 'B') + portalBuildIdentityBadge('logo', scoreView.teamBLogo, 'B') + '</div>' +
        '</div>' +
        (setLine ? '<div class="portal-set-line">' + setLine + '</div>' : '') +
        '<div class="portal-live-note">' + note + '</div>' +
        (liveButtons ? '<div class="portal-live-actions">' + liveButtons + '</div>' : '<div class="portal-live-empty">Ban tổ chức chưa dán link live công khai. Hãy thêm link Facebook / YouTube / TikTok ở tab Livestream.</div>') +
        (embedUrl ? '<div class="portal-embed-wrap"><iframe src="' + portalEscapeAttr(embedUrl) + '" title="YouTube Live" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe></div>' : '') +
      '</div>';
  }

  function portalBuildSection(title, subtitle, bodyHtml, id){
    return '' +
      '<section class="portal-section" id="' + id + '">' +
        '<div class="portal-section-head">' +
          '<div class="portal-section-kicker">TRUY CẬP NHANH</div>' +
          '<h2>' + portalEscapeHtml(title) + '</h2>' +
          '<p>' + portalEscapeHtml(subtitle) + '</p>' +
        '</div>' +
        '<div class="portal-section-card">' + bodyHtml + '</div>' +
      '</section>';
  }

  function buildPublicPortalHTML(){
    try{ if(typeof syncInfoDataFromMain === 'function') syncInfoDataFromMain(); }catch(e){}
    try{ if(typeof saveLivestreamSettings === 'function') saveLivestreamSettings(true); }catch(e){}
    try{ if(typeof renderSchedule === 'function') renderSchedule(); }catch(e){}
    try{ if(typeof renderLiveStudioPanel === 'function') renderLiveStudioPanel(); }catch(e){}
    try{ if(typeof renderRegulationViewer === 'function') renderRegulationViewer(); }catch(e){}

    var info = (state && state.tournamentInfo) || {};
    var title = portalEscapeHtml(info.title || 'Cổng vận động viên & khán giả');
    var sport = portalEscapeHtml(info.sport || 'Chưa cập nhật môn thi đấu');
    var content = portalEscapeHtml(info.content || 'Đang chờ cập nhật nội dung giải');
    var age = portalEscapeHtml(info.ageGroup || 'Chưa cập nhật nhóm tuổi');
    var formatText = typeof getFormatText === 'function' ? getFormatText(info.format || (state && state.format) || 'knockout') : portalEscapeHtml((info.format || (state && state.format) || 'knockout'));
    var description = portalEscapeHtml(info.description || 'Trang này dành cho vận động viên và khán giả theo dõi điều lệ, lịch thi đấu, bảng đấu - kết quả và tình trạng livestream của giải đấu.');
    var updatedAt = portalEscapeHtml(new Date().toLocaleString('vi-VN'));
