      if(!item.data.options) item.data.options = defaultOptions();
      if(typeof item.data.options.includeThirdPlace !== 'boolean') item.data.options.includeThirdPlace = false;
      if(!item.data.livestream) item.data.livestream = defaultLivestreamState();
      item.data.livestream = { ...defaultLivestreamState(), ...item.data.livestream };
      item.data.format = item.data.format || item.format || 'knockout';
      item.data.groupCount = Math.max(1, parseInt(item.data.groupCount) || 1);
