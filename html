    /* SCHEDULE */
    function buildKnockoutScheduleMatches(){
      if(!state.knockoutTree) return [];
      applyAdaptiveBracketSizing(state.knockoutTree);
      const layout = computeTreeLayout(state.knockoutTree);
      const codeMap = getDisplayCodeMap(layout);
      const roundMap = collectMatchesByRound(state.knockoutTree, {});
      const roundNumbers = Object.keys(roundMap).map(Number).sort((a, b) => a - b);
      const matches = [];

      roundNumbers.forEach((roundNo, idx) => {
        const phase = getPhaseNameByIndex(idx, roundNumbers.length);
        roundMap[roundNo].forEach(node => {
          const rs = getResultForMatch(node.id) || {};
          matches.push({
            phase, roundNo, matchId:node.id, matchCode:codeMap[node.id],
            teamA:getPrettyNodeLabel(node.left, codeMap),
            teamB:getPrettyNodeLabel(node.right, codeMap),
            ready:matchNeedsManualScore(node),
            autoAdvance:getAutoWinnerSide(node) > 0 && !matchNeedsManualScore(node),
            scoreA:Number.isFinite(rs.a) ? rs.a : '',
            scoreB:Number.isFinite(rs.b) ? rs.b : ''
          });
        });
      });

      const thirdPlaceContext = getThirdPlaceContext();
      if(thirdPlaceContext){
        const tpRs = getResultForMatch(thirdPlaceContext.matchId) || {};
        matches.push({
          phase:'Tranh hạng ba',
          roundNo:thirdPlaceContext.totalRounds,
          roundLabel:'Tranh hạng ba',
          matchId:thirdPlaceContext.matchId,
          matchCode:'TB',
          teamA:thirdPlaceContext.loserA?.name || `Thua ${codeMap[thirdPlaceContext.semis[0].id] || thirdPlaceContext.semis[0].id}`,
          teamB:thirdPlaceContext.loserB?.name || `Thua ${codeMap[thirdPlaceContext.semis[1].id] || thirdPlaceContext.semis[1].id}`,
          ready:!!thirdPlaceContext.loserA && !!thirdPlaceContext.loserB,
          autoAdvance:false,
          scoreA:Number.isFinite(tpRs.a) ? tpRs.a : '',
          scoreB:Number.isFinite(tpRs.b) ? tpRs.b : '',
          thirdPlace:true
        });
      }

      return matches;
    }

    function buildGroupRoundRobinRounds(){
      const groupRoundSets = (state.groups || []).map((group, g) => {
        const baseIndexes = group.map((_, idx) => idx);
        if(baseIndexes.length < 2) return [];

        const rotating = [...baseIndexes];
        if(rotating.length % 2 === 1) rotating.push(null);

        const roundCount = Math.max(rotating.length - 1, 0);
        const half = rotating.length / 2;
        const rounds = [];

        for(let roundIndex = 0; roundIndex < roundCount; roundIndex++){
          const roundMatches = [];

          for(let pairIndex = 0; pairIndex < half; pairIndex++){
            const left = rotating[pairIndex];
            const right = rotating[rotating.length - 1 - pairIndex];
            if(left === null || right === null) continue;

            const teamAIndex = Math.min(left, right);
            const teamBIndex = Math.max(left, right);
            const rs = state.results[`group_${g}_${teamAIndex}_${teamBIndex}`] || {};

            roundMatches.push({
              phase:`Bảng ${String.fromCharCode(65 + g)}`,
              roundIndex: roundIndex + 1,
              roundLabel:`Lượt trận ${roundIndex + 1}`,
              teamA:group[teamAIndex].name,
              teamB:group[teamBIndex].name,
              groupIndex:g,
              teamAIndex,
              teamBIndex,
              scoreA:Number.isFinite(rs.a) ? rs.a : '',
              scoreB:Number.isFinite(rs.b) ? rs.b : '',
              yellowA:Number.isFinite(rs.yellowA) ? rs.yellowA : 0,
              yellowB:Number.isFinite(rs.yellowB) ? rs.yellowB : 0,
              redA:Number.isFinite(rs.redA) ? rs.redA : 0,
              redB:Number.isFinite(rs.redB) ? rs.redB : 0
            });
          }

          rounds.push(roundMatches);

          const fixed = rotating[0];
          const rest = rotating.slice(1);
          rest.unshift(rest.pop());
          rotating.splice(0, rotating.length, fixed, ...rest);
        }

        return rounds;
      });

      const maxRounds = groupRoundSets.reduce((max, rounds) => Math.max(max, rounds.length), 0);
      const mergedRounds = [];

      for(let roundIndex = 0; roundIndex < maxRounds; roundIndex++){
        const roundMatches = [];
        groupRoundSets.forEach(rounds => {
          if(rounds[roundIndex]?.length){
            roundMatches.push(...rounds[roundIndex]);
          }
        });
        if(roundMatches.length) mergedRounds.push(roundMatches);
      }

      return mergedRounds;
    }

    function generateSchedule(){
      syncInfoDataFromMain();
      syncLegacyStartTime();
      const duration = Math.max(1, parseInt(document.getElementById('matchDuration').value) || 20);
      const breakMin = Math.max(0, parseInt(document.getElementById('breakDuration').value) || 0);
      const courts = Math.max(1, parseInt(document.getElementById('courtCount').value) || 1);

      try{
        if(state.format === 'knockout'){
          if(!state.knockoutTree){
            document.getElementById('schedule').innerHTML = `<div class="empty">Chưa tạo nhánh loại trực tiếp.</div>`;
            return;
          }
          const matches = buildKnockoutScheduleMatches();
          const grouped = {};
          matches.forEach(m => {
            if(!grouped[m.roundNo]) grouped[m.roundNo] = [];
            grouped[m.roundNo].push(m);
          });
          const roundNumbers = Object.keys(grouped).map(Number).sort((a, b) => a - b);
          state.schedule = scheduleRoundMatchesSequentially(roundNumbers.map(roundNo => grouped[roundNo]), duration, breakMin, courts);
        }else{
          if(!state.groups.length){
            document.getElementById('schedule').innerHTML = `<div class="empty">Chưa tạo vòng bảng.</div>`;
            return;
          }
          const groupedRounds = buildGroupRoundRobinRounds();
          state.schedule = scheduleRoundMatchesSequentially(groupedRounds, duration, breakMin, courts);
        }
      }catch(err){
        document.getElementById('schedule').innerHTML = `<div class="empty">${escapeHtml(err.message || 'Không xếp được lịch thi đấu.')}</div>`;
        alert(err.message || 'Không xếp được lịch thi đấu.');
        return;
      }

      normalizeAllMatchStatuses();
      saveState();
      updateTournamentInfoBar();
      updateMetrics();
      renderSchedule();
    }

    function renderSchedule(){
      const area = document.getElementById('schedule');
      area.innerHTML = '';
      if(!state.schedule.length){
        area.innerHTML = `<div class="empty">Chưa có lịch thi đấu.</div>`;
        renderAllStandings();
        return;
      }

      normalizeAllMatchStatuses();

      const sortedMatches = [...state.schedule].sort((a, b) => {
        return new Date(a.start) - new Date(b.start) || getCourtNumber(a.court) - getCourtNumber(b.court);
      });
      const courtNumbers = [...new Set(sortedMatches.map(m => getCourtNumber(m.court)))].sort((a, b) => a - b);
      const slotMap = new Map();
      sortedMatches.forEach(match => {
        const key = new Date(match.start).getTime();
        if(!slotMap.has(key)){
          slotMap.set(key, {
            start:new Date(match.start),
            end:new Date(match.end),
            matches:{},
            roundIndex: Number.isFinite(match.roundIndex) ? match.roundIndex : null,
            roundNo: Number.isFinite(match.roundNo) ? match.roundNo : null,
            roundLabel: match.roundLabel || match.phase || ''
          });
        }
        const slot = slotMap.get(key);
        slot.matches[getCourtNumber(match.court)] = match;
        if(slot.roundIndex === null && Number.isFinite(match.roundIndex)) slot.roundIndex = match.roundIndex;
        if(slot.roundNo === null && Number.isFinite(match.roundNo)) slot.roundNo = match.roundNo;
        if(!slot.roundLabel && (match.roundLabel || match.phase)) slot.roundLabel = match.roundLabel || match.phase || '';
      });
      const slots = [...slotMap.values()].sort((a, b) => a.start - b.start);
      const now = new Date();

      let html = `
        <div class="schedule-board-wrap">
          <div class="schedule-board-top">
            <div class="schedule-title-row">
              <div class="schedule-date-pill">${formatShortDate(slots[0].start)}${slots.length ? ` - ${formatShortDate(slots[slots.length - 1].start)}` : ''}</div>
              <div>
                <div class="schedule-board-title">Lịch thi đấu theo thời gian thực</div>
                <div class="schedule-board-sub">Mỗi ô trận giờ đã có <strong>trạng thái vận hành</strong>, <strong>đồng hồ thời gian thực</strong> và nút <strong>Liên kết live</strong> để mở thẳng trận đó sang trang livestream.</div>
              </div>
            </div>
            <div class="schedule-board-filters">
              <span class="status-badge-live on" style="gap:6px;">Giờ hiện tại: ${formatDateOnlyDisplay(now)} • ${formatTimeOnly(now)}</span>
              ${courtNumbers.map(courtNo => `<label class="court-chip"><input type="checkbox" checked disabled> Sân ${courtNo}</label>`).join('')}
            </div>
          </div>

          <div class="schedule-board">
            <div class="schedule-grid" style="grid-template-columns:82px repeat(${Math.max(courtNumbers.length,1)}, minmax(320px,1fr));">
              <div class="schedule-head-cell slot">Lượt</div>
              ${courtNumbers.map(courtNo => `<div class="schedule-head-cell">Sân ${courtNo}</div>`).join('')}
      `;

      let lastDateLabel = '';
      let lastRoundKey = '';
      const slotOrderMap = {};
      slots.forEach((slot, index) => {
        const currentDateLabel = formatDateOnlyDisplay(slot.start);
        lastDateLabel = currentDateLabel;

        const logicalRound = state.format === 'groups'
          ? (slot.roundIndex || index + 1)
          : (slot.roundNo || index + 1);
        const roundTitle = state.format === 'groups'
          ? `Lượt trận ${logicalRound}`
          : (slot.roundLabel || `Lượt trận ${index + 1}`);
        const roundKey = `${state.format}_${logicalRound}`;
        slotOrderMap[roundKey] = (slotOrderMap[roundKey] || 0) + 1;
        const slotOrderInRound = slotOrderMap[roundKey];

        if(roundKey !== lastRoundKey){
          html += `
          <div class="schedule-round-row">
            <div class="schedule-round-chip">
              <span>${roundTitle}</span>
              <span class="muted">${currentDateLabel} • ${formatTimeOnly(slot.start)} - ${formatTimeOnly(slot.end)}</span>
            </div>
          </div>`;
          lastRoundKey = roundKey;
        }

        const slotMainLabel = state.format === 'groups'
          ? `Lượt ${logicalRound}`
          : `Lượt ${index + 1}`;
        const slotSmallLabel = state.format === 'groups'
          ? `Ca ${slotOrderInRound} • ${formatTimeOnly(slot.start)}`
          : formatTimeOnly(slot.start);

        html += `<div class="schedule-slot-label"><div>${slotMainLabel}</div><div class="small">${slotSmallLabel}</div></div>`;

        courtNumbers.forEach(courtNo => {
          const m = slot.matches[courtNo];
          if(!m){
            html += `<div class="schedule-cell empty"></div>`;
            return;
