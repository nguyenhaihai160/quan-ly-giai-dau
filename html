                  ${isActive ? '<span class="content-chip" style="background:#fff4d8;border-color:#ffe3a0;color:#8b5e00;">Đang điều hành</span>' : ''}
                </div>
              </div>
            </div>
            <div class="content-item-note">${escapeHtml(item.note || 'Chưa có ghi chú riêng cho nội dung này.')}</div>
            <div class="content-item-actions">
