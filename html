    const layout = resolveScoreboardLayout(live.scoreboardLayout || 'auto');
    const detailsA = normalizeSetDetails(live.setDetailsA);
    const detailsB = normalizeSetDetails(live.setDetailsB);
    const setWins = computeSetWins(detailsA, detailsB, live.setA, live.setB, layout);
    const scoreA = live.scoreA !== '' ? sanitizeScoreValueLoose(live.scoreA) : sanitizeScoreValueLoose(seeded.a);
    const scoreB = live.scoreB !== '' ? sanitizeScoreValueLoose(live.scoreB) : sanitizeScoreValueLoose(seeded.b);
    const footballPeriod = sanitizeFootballPeriodValue(live.footballPeriod || 'H1');
    const defaultSegment = layout === 'football' ? getFootballPeriodLabel(footballPeriod) : (layout === 'tabletennis' ? 'Ván 1' : 'Set 1');
    let meta = live.scoreMeta || (match ? `${match.phase || 'Trận đấu'} • ${match.court || 'Chưa xếp sân'}` : 'Chưa chọn trận đấu');
    if(layout === 'football'){
      meta = live.scoreMeta || `${match ? `${match.phase || 'Trận đấu'} • ${match.court || 'Chưa xếp sân'}` : 'Bóng đá'} • ${getFootballPeriodLabel(footballPeriod)}${parsePositiveInt(live.footballAddedMinutes,0) ? ` • +${parsePositiveInt(live.footballAddedMinutes,0)}'` : ''}`;
    }
    return {
      teamA: match?.teamA || 'Đội A',
      teamB: match?.teamB || 'Đội B',
      scoreA: scoreA === '' ? 0 : scoreA,
      scoreB: scoreB === '' ? 0 : scoreB,
      setA: setWins.a,
      setB: setWins.b,
      setDetailsA: detailsA,
      setDetailsB: detailsB,
      segmentLabel: live.segmentLabel || defaultSegment,
