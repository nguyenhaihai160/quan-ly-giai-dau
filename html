      '.public-portal-body .schedule-card-actions{display:flex;justify-content:flex-start;gap:10px}' +
      '.public-portal-body .schedule-card-actions .status-pill{display:inline-flex}' +
      '@media (max-width:980px){.public-hero-grid{grid-template-columns:1fr}.public-hero-logo{width:110px;height:110px}.portal-score-slim{grid-template-columns:1fr;justify-items:center;text-align:center}.portal-score-team,.portal-score-team.is-right{justify-content:center;text-align:center}.portal-live-status{justify-items:start}.public-portal-shell{padding:12px}.portal-section-card{padding:14px}}' +
