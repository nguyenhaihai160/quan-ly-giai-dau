    function normalizeName(name){
      return String(name || '').trim().replace(/\s+/g, ' ');
    }

    function formatVNDateTime(date){
      return new Intl.DateTimeFormat('vi-VN', {
        day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'
      }).format(date);
    }


    function formatShortDate(date){
      const pad = n => String(n).padStart(2, '0');
      return `${pad(date.getDate())}/${pad(date.getMonth() + 1)}`;
    }

    function formatTimeOnly(date){
      const pad = n => String(n).padStart(2, '0');
      return `${pad(date.getHours())}:${pad(date.getMinutes())}`;
    }

    function formatDateOnly(date){
      const pad = n => String(n).padStart(2, '0');
      return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
    }

    function formatDateOnlyDisplay(date){
      const pad = n => String(n).padStart(2, '0');
      return `${pad(date.getDate())}/${pad(date.getMonth() + 1)}/${date.getFullYear()}`;
    }

    function formatDurationClock(ms){
      const totalSeconds = Math.max(0, Math.floor((ms || 0) / 1000));
      const hours = Math.floor(totalSeconds / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;
      const pad = n => String(n).padStart(2, '0');
      return hours > 0 ? `${pad(hours)}:${pad(minutes)}:${pad(seconds)}` : `${pad(minutes)}:${pad(seconds)}`;
    }

    function getAutoMatchStatusByTime(match){
      const start = new Date(match?.start || 0).getTime();
      const end = new Date(match?.end || 0).getTime();
      const now = Date.now();
      if(!Number.isFinite(start) || !Number.isFinite(end)) return 'scheduled';
      if(now < start) return 'scheduled';
      if(now >= start && now <= end) return 'live';
      return 'overtime';
    }

    function getMatchStatusClass(status){
      const map = {
        scheduled:'scheduled',
        waiting:'scheduled',
        pending:'scheduled',
        live:'live',
        paused:'paused',
        postponed:'postponed',
        overtime:'overtime',
        finished:'done',
        bye:'bye'
      };
      return map[status] || 'scheduled';
    }

    function getRealtimeInfo(match){
      const status = getMatchStatus(match);
      const start = new Date(match?.start || 0).getTime();
      const end = new Date(match?.end || 0).getTime();
      const now = Date.now();
      const validTimes = Number.isFinite(start) && Number.isFinite(end);
      const dateLine = validTimes
        ? `${formatDateOnlyDisplay(new Date(start))} • ${formatTimeOnly(new Date(start))} - ${formatTimeOnly(new Date(end))}`
        : 'Chưa có khung giờ';

      if(status === 'bye') return { main:'BYE / đi tiếp tự động', sub:dateLine };
      if(status === 'finished'){
        const duration = validTimes ? Math.max(0, end - start) : 0;
        return { main:`Đã kết thúc • ${formatDurationClock(duration)}`, sub:dateLine };
      }
      if(status === 'paused'){
        const elapsed = validTimes ? Math.max(0, now - start) : 0;
        return { main:`Tạm dừng • ${formatDurationClock(elapsed)}`, sub:dateLine };
      }
      if(status === 'postponed'){
        return { main:'Trận đang tạm hoãn', sub:dateLine };
      }
      if(status === 'live'){
        const elapsed = validTimes ? Math.max(0, now - start) : 0;
        const remaining = validTimes ? end - now : 0;
        return {
          main:`Đang diễn ra • ${formatDurationClock(elapsed)}`,
          sub: remaining >= 0 ? `Còn ${formatDurationClock(remaining)} đến giờ dự kiến kết thúc` : `Quá giờ ${formatDurationClock(Math.abs(remaining))}`
        };
      }
      if(status === 'overtime'){
        const overdue = validTimes ? Math.max(0, now - end) : 0;
        return { main:`Quá giờ • ${formatDurationClock(overdue)}`, sub:`Đã qua giờ kết thúc dự kiến • ${dateLine}` };
      }
      const countdown = validTimes ? Math.max(0, start - now) : 0;
      return { main:`Còn ${formatDurationClock(countdown)}`, sub:`Chuẩn bị vào trận • ${dateLine}` };
    }

    function getMatchByKey(matchKey){
      return (state.schedule || []).find(match => getScheduleMatchKey(match) === matchKey) || null;
    }

    function renderRealtimeMarkup(match, statusKey){
      const info = getRealtimeInfo(match);
      return `
        <div class=\"schedule-runtime-box\" data-match-key=\"${escapeHtml(statusKey)}\">
