  function ensurePublicPortalTab(){
    var tabs = document.querySelector('.top-tabs');
    if(tabs && !tabs.querySelector('[data-tab="' + PUBLIC_PORTAL_TAB_ID + '"]')){
      var btn = document.createElement('button');
      btn.className = 'tab-btn';
      btn.dataset.tab = PUBLIC_PORTAL_TAB_ID;
      btn.type = 'button';
      btn.textContent = 'VĐV & khán giả';
      btn.onclick = function(){ switchTab(PUBLIC_PORTAL_TAB_ID); };
      var standingsBtn = tabs.querySelector('[data-tab="tabStandings"]');
      if(standingsBtn) tabs.insertBefore(btn, standingsBtn);
      else tabs.appendChild(btn);
    }

    if(!document.getElementById(PUBLIC_PORTAL_TAB_ID)){
      var panel = document.createElement('div');
      panel.id = PUBLIC_PORTAL_TAB_ID;
      panel.className = 'tab-panel';
      panel.innerHTML = '' +
        '<div class="card public-portal-admin-card">' +
          '<div class="public-portal-admin-head">' +
            '<div class="public-portal-admin-copy">' +
              '<h2 class="section-title">Trang dành cho vận động viên & khán giả</h2>' +
              '<p>Từ đây bạn có thể mở một trang xem công khai, gọn gàng hơn so với trang quản lý. Trang này lấy dữ liệu trực tiếp từ điều lệ, lịch thi đấu, bảng đấu - kết quả và cấu hình livestream hiện có.</p>' +
              '<div class="public-portal-toolbar">' +
                '<span class="meta-chip">Điều lệ • Lịch thi đấu • Bảng đấu & kết quả • Live</span>' +
                '<span class="portal-launch-pill" id="publicPortalStamp">Chưa đồng bộ</span>' +
              '</div>' +
            '</div>' +
            '<div class="public-portal-toolbar">' +
              '<button class="btn-green" type="button" onclick="refreshPublicPortalPreview()">Làm mới cổng công khai</button>' +
              '<button class="btn-blue" type="button" onclick="openPublicPortalWindow()">Mở trang riêng</button>' +
              '<button type="button" onclick="copyPublicPortalSummary()">Copy mô tả trang xem</button>' +
            '</div>' +
          '</div>' +
          '<div class="public-portal-frame-wrap"><iframe id="publicPortalFrame" title="Cổng vận động viên và khán giả"></iframe></div>' +
        '</div>';
      var standingsPanel = document.getElementById('tabStandings');
      if(standingsPanel && standingsPanel.parentNode){
        standingsPanel.parentNode.insertBefore(panel, standingsPanel);
      }else{
        var anyPanel = document.querySelector('.tab-panel:last-child');
        if(anyPanel && anyPanel.parentNode) anyPanel.parentNode.appendChild(panel);
      }
    }

    var homeQuick = document.querySelector('#tabHome .home-quick-grid');
    if(homeQuick && !document.getElementById('homePortalEntry')){
      var homeBtn = document.createElement('button');
      homeBtn.className = 'home-action portal-entry';
      homeBtn.id = 'homePortalEntry';
      homeBtn.type = 'button';
      homeBtn.onclick = function(){ switchTab(PUBLIC_PORTAL_TAB_ID); };
      homeBtn.innerHTML = '<div class="home-action-title">Trang VĐV & khán giả</div><div class="home-action-note">Mở cổng xem công khai để theo dõi điều lệ, lịch thi đấu, bảng đấu - kết quả và link live.</div>';
      homeQuick.appendChild(homeBtn);
    }
  }

  window.refreshPublicPortalPreview = function(){
    ensurePublicPortalTab();
    var frame = document.getElementById('publicPortalFrame');
    if(!frame) return;
    var html = buildPublicPortalHTML();
    frame.srcdoc = html;
    var stamp = document.getElementById('publicPortalStamp');
    if(stamp) stamp.textContent = 'Đã đồng bộ ' + new Date().toLocaleTimeString('vi-VN');
  };

  window.openPublicPortalWindow = function(){
    var html = buildPublicPortalHTML();
    var win = window.open('', '_blank');
    if(!win) return;
    win.document.open();
    win.document.write(html);
    win.document.close();
  };

  window.copyPublicPortalSummary = async function(){
    var info = (state && state.tournamentInfo) || {};
    var text = [
      'CỔNG VẬN ĐỘNG VIÊN & KHÁN GIẢ',
      info.title || 'Tên giải đang được cập nhật',
      info.sport ? ('Môn: ' + info.sport) : '',
      info.content ? ('Nội dung: ' + info.content) : '',
      'Trang xem gồm: Điều lệ giải, lịch thi đấu, bảng đấu & kết quả, live stream.'
    ].filter(Boolean).join('\n');
    try{
      await navigator.clipboard.writeText(text);
      alert('Đã copy mô tả cổng xem dành cho vận động viên và khán giả.');
    }catch(e){
      alert(text);
    }
  };

  function wrapPortalRefresh(fnName){
    var original = window[fnName];
    if(typeof original !== 'function' || original.__portalWrapped) return;
    var wrapped = function(){
      var result = original.apply(this, arguments);
      clearTimeout(wrapped.__portalTimer);
      wrapped.__portalTimer = setTimeout(function(){
        var portalPanel = document.getElementById(PUBLIC_PORTAL_TAB_ID);
        if(portalPanel && !portalPanel.classList.contains('hidden') && typeof window.refreshPublicPortalPreview === 'function'){
          window.refreshPublicPortalPreview();
        }
      }, 120);
      return result;
    };
    wrapped.__portalWrapped = true;
    window[fnName] = wrapped;
  }

  function bootPublicPortal(){
    ensurePublicPortalTab();
    ['saveState','saveAssets','renderSchedule','renderLiveStudioPanel','renderRegulationViewer','renderAllStandings','restoreTournament'].forEach(wrapPortalRefresh);
    if(typeof window.switchTab === 'function' && !window.switchTab.__portalWrapped){
      var oldSwitchTab = window.switchTab;
      window.switchTab = function(){
        var result = oldSwitchTab.apply(this, arguments);
        var tabId = arguments[0];
        if(tabId === PUBLIC_PORTAL_TAB_ID && typeof window.refreshPublicPortalPreview === 'function'){
          setTimeout(window.refreshPublicPortalPreview, 80);
        }
        return result;
      };
      window.switchTab.__portalWrapped = true;
    }
    setTimeout(function(){
      if((state && state.activeTab) === PUBLIC_PORTAL_TAB_ID) window.refreshPublicPortalPreview();
    }, 120);
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', function(){ setTimeout(bootPublicPortal, 0); });
  }else{
    setTimeout(bootPublicPortal, 0);
  }
})();
</script>
