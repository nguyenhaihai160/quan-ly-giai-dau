    const flag = side === 'A' ? live.teamAFlag : live.teamBFlag;
    box.innerHTML = img
      ? `<div class="live-logo-preview-thumb"><img src="${img}" alt="logo ${side}"></div><div class="live-logo-preview-copy">Đã nạp logo ${side}${flag ? ` • Cờ ${htmlEscape(flag)}` : ''}</div>`
      : `<div class="live-logo-preview-thumb">${side}</div><div class="live-logo-preview-copy">Chưa có logo CLB${flag ? ` • Cờ ${htmlEscape(flag)}` : ''}</div>`;
  }

  function buildSetDetailHTML(scoreView){
    if(!['badminton','pickleball','tabletennis','broadcast'].includes(scoreView.resolvedLayout)) return '';
    const labels = getSetSlotLabels(scoreView.resolvedLayout);
    const hasAny = scoreView.setDetailsA.some((v, idx) => v !== '' || scoreView.setDetailsB[idx] !== '');
    if(!hasAny && scoreView.resolvedLayout !== 'broadcast') return '';
    return labels.map((label, idx) => {
      const a = scoreView.setDetailsA[idx];
      const b = scoreView.setDetailsB[idx];
      const display = (a === '' && b === '') ? '-:-' : `${a === '' ? '-' : a}:${b === '' ? '-' : b}`;
      return `<div class="live-set-chip"><span>${htmlEscape(label)}</span><strong>${htmlEscape(display)}</strong></div>`;
    }).join('');
  }

  function buildFootballHTML(scoreView){
    if(scoreView.resolvedLayout !== 'football') return '';
    const chips = [
      `<div class="live-football-chip"><span>Giai đoạn</span><strong>${htmlEscape(getFootballPeriodLabel(scoreView.footballPeriod))}</strong></div>`
    ];
    if(scoreView.footballAddedMinutes > 0){
      chips.push(`<div class="live-football-chip"><span>Bù giờ</span><strong>+${htmlEscape(scoreView.footballAddedMinutes)}'</strong></div>`);
    }
    chips.push(`<div class="live-football-chip"><span>Tỷ số</span><strong>${htmlEscape(scoreView.scoreA)} - ${htmlEscape(scoreView.scoreB)}</strong></div>`);
    return chips.join('');
