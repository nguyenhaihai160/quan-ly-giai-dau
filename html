    function setLiveOverlayPosition(x, y, options = {}){
      const overlay = document.getElementById('liveScoreOverlay');
      const shell = document.getElementById('liveVideoShell');
      let nextX = Number.isFinite(Number(x)) ? Number(x) : 0;
      let nextY = Number.isFinite(Number(y)) ? Number(y) : 0;
      if(overlay && shell && overlay.offsetWidth && overlay.offsetHeight){
        const live = { ...defaultLivestreamState(), ...(state.livestream || {}) };
        const scale = clampScoreboardScale(live.scoreboardScale || 100) / 100;
        const baseLeft = Math.max(8, shell.clientWidth - overlay.offsetWidth - 22);
        const baseTop = 28;
        const overlayWidth = overlay.offsetWidth * scale;
        const overlayHeight = overlay.offsetHeight * scale;
        const minX = 8 - baseLeft;
        const maxX = Math.max(minX, shell.clientWidth - overlayWidth - 8 - baseLeft);
        const minY = 8 - baseTop;
        const maxY = Math.max(minY, shell.clientHeight - overlayHeight - 8 - baseTop);
        nextX = Math.max(minX, Math.min(maxX, nextX));
        nextY = Math.max(minY, Math.min(maxY, nextY));
      }
      if(overlay){
        overlay.style.setProperty('--overlay-x', `${Math.round(nextX)}px`);
        overlay.style.setProperty('--overlay-y', `${Math.round(nextY)}px`);
      }
      if(options.persist){
        const live = { ...defaultLivestreamState(), ...(state.livestream || {}) };
        live.overlayX = Math.round(nextX);
        live.overlayY = Math.round(nextY);
        state.livestream = live;
        saveState();
      }
      return { x:Math.round(nextX), y:Math.round(nextY) };
    }

