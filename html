      resolvedLayout: layout,
      scoreboardOrientation: sanitizeScoreboardOrientationValue(live.scoreboardOrientation || 'auto'),
      resolvedOrientation: resolveOrientation(layout, live.scoreboardOrientation || 'auto'),
      scoreboardAnimation: sanitizeScoreboardAnimation(live.scoreboardAnimation || 'slide-up'),
