    async function startScreenShare(){
      if(!navigator.mediaDevices || !navigator.mediaDevices.getDisplayMedia){
        alert('Trình duyệt không hỗ trợ chia sẻ màn hình.');
        return;
      }
      try{
        disconnectLiveCamera(false);
        const stream = await navigator.mediaDevices.getDisplayMedia({ video:true, audio:true });
        liveMediaState.stream = stream;
        liveMediaState.usingScreen = true;
        attachLiveStream(stream);
        stream.getVideoTracks().forEach(track => {
          track.onended = () => {
            disconnectLiveCamera(false);
            updateLiveCameraStatus('Chia sẻ màn hình đã kết thúc.', 'idle');
            renderLivestreamSummary();
          };
        });
        updateLiveCameraStatus('Đang xem trước nguồn chia sẻ màn hình.', 'ok');
        renderLivestreamSummary();
      }catch(err){
        console.error(err);
        updateLiveCameraStatus('Không bật được chế độ chia sẻ màn hình.', 'warn');
      }
    }

