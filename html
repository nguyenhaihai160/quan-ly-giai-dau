    function exportExcel(){
      syncInfoDataFromMain();
      const infoRows = [{
        TieuDe: state.tournamentInfo.title,
        MonThiDau: state.tournamentInfo.sport,
        NoiDung: state.tournamentInfo.content,
        NhomTuoi: state.tournamentInfo.ageGroup,
