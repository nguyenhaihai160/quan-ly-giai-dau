    function addTeam(){
      const nameInput = document.getElementById('teamName');
      const seedInput = document.getElementById('teamSeed');
      const name = normalizeName(nameInput.value);
      if(!name){ alert('Vui lòng nhập tên đội.'); return; }

      const exists = state.teams.some(t => t.name.toLowerCase() === name.toLowerCase());
      if(exists){ alert('Tên đội đã tồn tại.'); return; }

      let seed = parseInt(seedInput.value);
      if(isNaN(seed) || seed <= 0) seed = state.teams.length + 1;

      state.teams.push({
        id: Date.now() + '_' + Math.random().toString(36).slice(2,7),
        name,
        seed
      });

      nameInput.value = '';
      seedInput.value = '';
      saveState();
      renderTeams();
      updateMetrics();
    }

