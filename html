    async function prepareBracketExportSurface(){
      const target = document.getElementById('bracketStage');
      if(!target) return null;

      switchTab('tabBracket');
      target.classList.add('pdf-exporting');

      await new Promise(resolve => requestAnimationFrame(() => requestAnimationFrame(resolve)));

      if(state.format === 'knockout' && state.knockoutTree){
        renderBracket();
        await new Promise(resolve => requestAnimationFrame(resolve));
        drawBracketLines();
      }

      target.scrollTop = 0;
      target.scrollLeft = 0;
      return target;
    }

    function buildExportFileName(ext){
      const base = (state?.tournamentInfo?.title || 'so_do_giai_dau')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-zA-Z0-9_-]+/g, '_')
        .replace(/^_+|_+$/g, '')
        .slice(0, 60) || 'so_do_giai_dau';
      return `${base}_A4.${ext}`;
    }

    async function exportBracketImage(){
      const target = await prepareBracketExportSurface();
      if(!target){ alert('Không tìm thấy sơ đồ.'); return; }

      const captureWidth = Math.max(target.clientWidth, target.offsetWidth);
      const captureHeight = Math.max(target.clientHeight, target.offsetHeight);

      try{
        const canvas = await html2canvas(target, {
          scale:2,
          backgroundColor:'#bfe0ec',
          useCORS:true,
          width:captureWidth,
          height:captureHeight,
          windowWidth:captureWidth,
          windowHeight:captureHeight,
          scrollX:0,
          scrollY:0
        });

        const link = document.createElement('a');
        link.download = buildExportFileName('png');
        link.href = canvas.toDataURL('image/png');
        link.click();
      }finally{
        target.classList.remove('pdf-exporting');
      }
    }

    async function exportBracketPDF(){
      const target = await prepareBracketExportSurface();
      if(!target){ alert('Không tìm thấy sơ đồ.'); return; }

      if(!window.jspdf || !window.jspdf.jsPDF){
        target.classList.remove('pdf-exporting');
        alert('Thư viện PDF chưa tải xong. Vui lòng thử lại sau vài giây.');
        return;
      }

      const captureWidth = Math.max(target.clientWidth, target.offsetWidth);
      const captureHeight = Math.max(target.clientHeight, target.offsetHeight);

      try{
        const canvas = await html2canvas(target, {
          scale:2,
          backgroundColor:'#bfe0ec',
          useCORS:true,
          width:captureWidth,
          height:captureHeight,
          windowWidth:captureWidth,
          windowHeight:captureHeight,
          scrollX:0,
          scrollY:0
        });

        const { jsPDF } = window.jspdf;
        const pdf = new jsPDF({
          orientation:'landscape',
          unit:'mm',
          format:'a4',
          compress:true
        });

        const pageWidth = pdf.internal.pageSize.getWidth();
        const pageHeight = pdf.internal.pageSize.getHeight();
        const margin = 6;
        const ratio = Math.min(
          (pageWidth - margin * 2) / canvas.width,
          (pageHeight - margin * 2) / canvas.height
        );

        const imgWidth = canvas.width * ratio;
        const imgHeight = canvas.height * ratio;
        const x = (pageWidth - imgWidth) / 2;
        const y = (pageHeight - imgHeight) / 2;

        pdf.addImage(canvas.toDataURL('image/png'), 'PNG', x, y, imgWidth, imgHeight, undefined, 'FAST');
        pdf.save(buildExportFileName('pdf'));
      }catch(err){
        console.error(err);
        alert('Không xuất được PDF. Vui lòng thử lại.');
      }finally{
        target.classList.remove('pdf-exporting');
      }
    }

    function resetData(){
      if(!confirm('Bạn chắc chắn muốn xóa toàn bộ dữ liệu?')) return;
      localStorage.removeItem(STORAGE_KEY);
      sessionStorage.removeItem(ASSET_STORAGE_KEY);
      location.reload();
    }

    function restoreUI(){
      const now = new Date();
      const today = formatDateOnly(now);
      if(!document.getElementById('startTime').value){
        document.getElementById('startTime').value = toInputDateTimeValue(now);
      }
      if(document.getElementById('scheduleFromDate') && !document.getElementById('scheduleFromDate').value){
        document.getElementById('scheduleFromDate').value = today;
      }
      if(document.getElementById('scheduleToDate') && !document.getElementById('scheduleToDate').value){
        document.getElementById('scheduleToDate').value = today;
      }
      if(document.getElementById('dailyStartTime') && !document.getElementById('dailyStartTime').value){
        document.getElementById('dailyStartTime').value = '08:00';
      }
      if(document.getElementById('dailyEndTime') && !document.getElementById('dailyEndTime').value){
        document.getElementById('dailyEndTime').value = '20:00';
      }
      syncLegacyStartTime();
      const contentFormatInput = document.getElementById('contentFormatInput');
      if(contentFormatInput) contentFormatInput.value = state.format || 'knockout';
      applyOptionsToUI();
      toggleFormatFields();
      refreshLivestreamMatchOptions();
      applyLivestreamToUI();
      renderAllAssets();
      updateMetrics();
      updateHomeDashboard();
    }

    function restoreTournament(){
      if(state.format === 'knockout' && state.knockoutTree){
        assignRounds(state.knockoutTree);
        renderBracket();
        renderGroupAreaEmpty();
      }else if(state.format === 'groups' && state.groups?.length){
        renderGroups();
        renderBracketEmpty();
      }else{
        renderBracketEmpty();
        document.getElementById('groupArea').innerHTML = `<div class="empty">Chưa tạo giải đấu.</div>`;
      }
      renderSchedule();
      renderAllStandings();
      updateHomeDashboard();
    }

    function escapeHtml(str){
      return String(str ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    window.addEventListener('resize', () => {
      if(state.format === 'knockout' && state.knockoutTree){
        requestAnimationFrame(drawBracketLines);
      }
      setLiveOverlayPosition(state.livestream?.overlayX || 0, state.livestream?.overlayY || 0, { persist:false });
    });

    document.addEventListener('keydown', function(e){
      if(e.target && e.target.id === 'teamName' && e.key === 'Enter') addTeam();
      if(e.target && e.target.id === 'contentNameInput' && e.key === 'Enter') addTournamentContent();
    });

    ['scheduleFromDate','scheduleToDate','dailyStartTime','dailyEndTime'].forEach(id => {
      const el = document.getElementById(id);
      if(el){
        el.addEventListener('change', syncLegacyStartTime);
      }
    });

    window.addEventListener('beforeunload', () => {
      try{
        saveState();
        saveAssets();
        disconnectLiveCamera(false);
        liveReplayState.clips.forEach(item => { try{ URL.revokeObjectURL(item.url); }catch(e){} });
        if(liveAdAssets.imageUrl) try{ URL.revokeObjectURL(liveAdAssets.imageUrl); }catch(e){}
        if(liveAdAssets.videoUrl) try{ URL.revokeObjectURL(liveAdAssets.videoUrl); }catch(e){}
      }catch(e){
        console.warn('Tự lưu trước khi đóng trang không thành công', e);
      }
    });

    document.addEventListener('visibilitychange', () => {
      if(document.visibilityState === 'hidden'){
        try{
          saveState();
          saveAssets();
        }catch(e){
          console.warn('Tự lưu khi ẩn trang không thành công', e);
        }
      }
    });

    loadState();
    loadAssets();

    if(!state.teams) state.teams = [];
    if(!state.results) state.results = {};
    if(!state.schedule) state.schedule = [];
    if(!state.groups) state.groups = [];
    if(!state.knockoutTree) state.knockoutTree = null;
    if(!state.activeTab) state.activeTab = 'tabHome';
    if(!state.activeContentId) state.activeContentId = '';
    if(!state.tournamentContents) state.tournamentContents = [];
    state.tournamentContents.forEach(ensureContentDataShape);
    if(!state.tournamentInfo){
      state.tournamentInfo = { title:'', sport:'', content:'', ageGroup:'', format:'knockout', description:'' };
    }
    state.options = { ...defaultOptions(), ...(state.options || {}) };
    state.livestream = { ...defaultLivestreamState(), ...(state.livestream || {}) };

    renderTeams();
    renderTournamentContents();
    restoreAppShell();
    setupLiveOverlayDrag();
    restoreUI();
    restoreTournament();
    updateTournamentInfoBar();
    updateMetrics();
    ensureRealtimeTicker();
  </script>

