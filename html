    return type === 'application/pdf' || type.indexOf('image/') === 0 || type.indexOf('text/') === 0 || /\.(pdf|png|jpe?g|webp|gif|txt|md)$/i.test(name);
  }

  function buildRegulationViewerHTML(reg){
    if(!reg || (!reg.data && !reg.text)){
      return '<div class="home-regulation-viewer is-empty">Chưa có điều lệ giải. Bạn có thể tải lên file PDF, ảnh hoặc văn bản để xem trực tiếp ngay tại trang chủ.</div>';
    }
    var type = String(reg.type || '').toLowerCase();
    var name = String(reg.name || '').toLowerCase();
    if(type === 'application/pdf' || /\.pdf$/i.test(name)){
      return '<div class="home-regulation-viewer"><iframe src="' + safeEscape(reg.data || '') + '" title="Điều lệ giải"></iframe></div>';
    }
    if(type.indexOf('image/') === 0 || /\.(png|jpe?g|webp|gif)$/i.test(name)){
      return '<div class="home-regulation-viewer"><img src="' + safeEscape(reg.data || '') + '" alt="Điều lệ giải"></div>';
    }
    if(reg.text || type.indexOf('text/') === 0 || /\.(txt|md)$/i.test(name)){
      return '<div class="home-regulation-viewer"><pre class="regulation-text">' + safeEscape(reg.text || '') + '</pre></div>';
    }
    return '<div class="home-regulation-viewer"><div class="regulation-fallback"><strong>Đã tải file điều lệ: ' + safeEscape(reg.name || 'Tập tin') + '</strong><div>Định dạng này chưa xem trực tiếp tốt trong HTML offline. Nên chuyển file điều lệ sang PDF để xem ngay trên trang chủ.</div></div></div>';
  }

  function ensureHomeRegulationCard(){
    var home = document.getElementById('tabHome');
    if(!home || document.getElementById('homeRegulationCard')) return;
    var stacks = home.querySelectorAll('.home-stack');
    if(!stacks.length) return;
    var targetStack = stacks[1] || stacks[0];
    var card = document.createElement('div');
    card.className = 'card home-regulation-card';
    card.id = 'homeRegulationCard';
    card.innerHTML = '' +
      '<div class="home-regulation-head">' +
        '<div class="home-regulation-copy">' +
          '<h2 class="section-title">Điều lệ giải</h2>' +
          '<p class="home-regulation-text">Tải điều lệ để ban tổ chức, trọng tài và vận động viên có thể xem nhanh ngay tại trang chủ. Nên dùng PDF để xem ổn định nhất.</p>' +
          '<div class="home-regulation-meta">' +
            '<span class="home-regulation-chip" id="regulationStatusChip">Chưa tải điều lệ</span>' +
            '<span class="home-regulation-chip" id="regulationMetaInfo">PDF được ưu tiên để xem trực tiếp</span>' +
          '</div>' +
          '<div class="regulation-upload-inline">' +
            '<input id="regulationFileInput" type="file" accept=".pdf,image/*,.txt,.md" onchange="handleRegulationUpload(event)">' +
          '</div>' +
          '<div class="home-regulation-mini-note">Hệ thống hỗ trợ xem trực tiếp PDF, ảnh và văn bản ngắn. Nếu điều lệ đang ở Word, nên xuất sang PDF trước khi tải lên.</div>' +
        '</div>' +
        '<div class="home-regulation-actions">' +
          '<div class="inline-actions">' +
            '<button id="regulationOpenBtn" class="btn-blue home-regulation-open-btn" type="button" onclick="openRegulationInNewWindow()" disabled>Mở lớn</button>' +
            '<button id="regulationClearBtn" class="btn-gray" type="button" onclick="clearRegulationFile()">Xóa điều lệ</button>' +
          '</div>' +
        '</div>' +
      '</div>' +
      '<div id="homeRegulationViewerWrap">' + buildRegulationViewerHTML(assets && assets.regulation ? assets.regulation : null) + '</div>';

    var liveBox = targetStack.querySelector('.live-status-box');
    if(liveBox){
      liveBox.insertAdjacentElement('afterend', card);
    }else{
      targetStack.insertAdjacentElement('afterbegin', card);
    }
  }

  window.renderRegulationViewer = function(){
    ensureHomeRegulationCard();
    var reg = assets && assets.regulation ? assets.regulation : null;
    var wrap = document.getElementById('homeRegulationViewerWrap');
    var status = document.getElementById('regulationStatusChip');
    var info = document.getElementById('regulationMetaInfo');
    var openBtn = document.getElementById('regulationOpenBtn');
    if(wrap) wrap.innerHTML = buildRegulationViewerHTML(reg);
    if(status){
      status.textContent = reg && (reg.data || reg.text) ? 'Đã tải điều lệ' : 'Chưa tải điều lệ';
    }
    if(info){
      if(reg && (reg.data || reg.text)){
        var when = reg.updatedAt ? new Date(reg.updatedAt).toLocaleString('vi-VN') : '';
        info.textContent = [reg.name || 'Tập tin', when ? ('Cập nhật: ' + when) : ''].filter(Boolean).join(' • ');
      }else{
        info.textContent = 'PDF được ưu tiên để xem trực tiếp';
      }
    }
    if(openBtn) openBtn.disabled = !(reg && (reg.data || reg.text) && regulationAcceptsPreview(reg));
  };

  window.handleRegulationUpload = function(event){
    var file = event && event.target && event.target.files ? event.target.files[0] : null;
    if(!file) return;
    ensureSaveAssetsFallback();
    var name = file.name || 'dieu-le';
    var type = file.type || (name.toLowerCase().endsWith('.pdf') ? 'application/pdf' : '');
    var isText = type.indexOf('text/') === 0 || /\.(txt|md)$/i.test(name);
    if(isText){
      var readerText = new FileReader();
      readerText.onload = function(ev){
        assets.regulation = { name:name, type:type || 'text/plain', text:String(ev.target.result || ''), updatedAt:Date.now() };
        if(typeof saveAssets === 'function') saveAssets();
        renderRegulationViewer();
      };
      readerText.readAsText(file, 'utf-8');
    }else{
      var readerData = new FileReader();
      readerData.onload = function(ev){
        assets.regulation = { name:name, type:type || 'application/octet-stream', data:String(ev.target.result || ''), updatedAt:Date.now() };
        if(typeof saveAssets === 'function') saveAssets();
        renderRegulationViewer();
      };
      readerData.readAsDataURL(file);
    }
    if(event && event.target) event.target.value = '';
  };

  window.clearRegulationFile = function(){
    if(!assets) return;
    assets.regulation = null;
    if(typeof saveAssets === 'function') saveAssets();
    renderRegulationViewer();
  };

  window.openRegulationInNewWindow = function(){
    var reg = assets && assets.regulation ? assets.regulation : null;
    if(!reg || !(reg.data || reg.text) || !regulationAcceptsPreview(reg)) return;
    var win = window.open('', '_blank');
    if(!win) return;
    var title = safeEscape(reg.name || 'Điều lệ giải');
    if(reg.text){
      win.document.write('<!doctype html><html><head><meta charset="utf-8"><title>' + title + '</title><style>body{font-family:Arial,Helvetica,sans-serif;margin:0;padding:24px;line-height:1.7;color:#1f3245;background:#f7fbff}pre{white-space:pre-wrap;word-break:break-word;font-family:Arial,Helvetica,sans-serif}</style></head><body><pre>' + safeEscape(reg.text || '') + '</pre></body></html>');
      win.document.close();
      return;
    }
    if((reg.type || '').toLowerCase() === 'application/pdf' || /\.pdf$/i.test(reg.name || '')){
      win.document.write('<!doctype html><html><head><meta charset="utf-8"><title>' + title + '</title><style>html,body{margin:0;height:100%;background:#0c1930}iframe{width:100%;height:100%;border:0}</style></head><body><iframe src="' + safeEscape(reg.data || '') + '"></iframe></body></html>');
      win.document.close();
      return;
    }
    win.document.write('<!doctype html><html><head><meta charset="utf-8"><title>' + title + '</title><style>html,body{margin:0;height:100%;display:flex;align-items:center;justify-content:center;background:#0c1930}img{max-width:100%;max-height:100%;object-fit:contain}</style></head><body><img src="' + safeEscape(reg.data || '') + '" alt="' + title + '"></body></html>');
    win.document.close();
  };

  function makeLiveCardFoldable(card, collapsedDefault){
    if(!card || card.dataset.foldReady === '1') return;
    var heading = card.querySelector('h2.section-title, h3.sub-title');
    if(!heading) return;
    var title = heading.textContent.trim();
    var body = document.createElement('div');
    body.className = 'live-fold-body';
    while(heading.nextSibling){
      body.appendChild(heading.nextSibling);
    }
    var toggle = document.createElement('button');
    toggle.type = 'button';
    toggle.className = 'live-fold-toggle';
    toggle.innerHTML = '<span class="live-fold-title">' + safeEscape(title) + '</span><span class="live-fold-icon">' + (collapsedDefault ? '+' : '−') + '</span>';
    heading.replaceWith(toggle);
    card.appendChild(body);
    card.classList.add('live-fold-card');
    if(collapsedDefault) card.classList.add('is-collapsed');
    toggle.addEventListener('click', function(){
      card.classList.toggle('is-collapsed');
      var icon = toggle.querySelector('.live-fold-icon');
      if(icon) icon.textContent = card.classList.contains('is-collapsed') ? '+' : '−';
    });
    card.dataset.foldReady = '1';
  }

  function compactifyLivestreamLayout(){
    var tab = document.getElementById('tabLivestream');
    if(!tab) return;
    tab.classList.add('live-compact-mode');
    var side = tab.querySelector('.live-center-side');
    if(side && !side.dataset.compactReady){
      var cards = Array.prototype.slice.call(side.children);
      var primary = document.createElement('div');
      primary.className = 'live-side-primary-grid';
      var secondary = document.createElement('div');
      secondary.className = 'live-side-secondary-grid';
      cards.forEach(function(card){
        var titleEl = card.querySelector('h2.section-title, h3.sub-title');
        var title = titleEl ? titleEl.textContent.trim() : '';
        if(title === 'Thiết lập trận live & mạng xã hội' || title === 'Bảng tỷ số live & broadcast overlay' || title === 'Đồng hồ trận đấu lớn'){
          primary.appendChild(card);
        }else{
          secondary.appendChild(card);
        }
      });
      side.innerHTML = '';
      side.appendChild(primary);
      side.appendChild(secondary);
      Array.prototype.forEach.call(secondary.children, function(card){ makeLiveCardFoldable(card, true); });
      side.dataset.compactReady = '1';
    }
  }

  function bootPatch(){
    ensureSaveAssetsFallback();
    ensureHomeRegulationCard();
    compactifyLivestreamLayout();
    if(typeof window.updateHomeDashboard === 'function' && !window.updateHomeDashboard.__regWrapped){
      var oldUpdateHomeDashboard = window.updateHomeDashboard;
      window.updateHomeDashboard = function(){
        oldUpdateHomeDashboard.apply(this, arguments);
        renderRegulationViewer();
      };
      window.updateHomeDashboard.__regWrapped = true;
    }
    renderRegulationViewer();
    if(typeof window.applyLivestreamToUI === 'function') window.applyLivestreamToUI();
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', function(){ setTimeout(bootPatch, 0); });
  }else{
    setTimeout(bootPatch, 0);
  }
})();
</script>

