    function estimateMatchCount(){
      const teamCount = state.teams.length;
      if(state.format === 'knockout') return Math.max(0, teamCount - 1);

      const groupCount = Math.max(1, Math.min(state.groupCount || 2, teamCount || 1));
      if(teamCount < 2) return 0;
      const base = Math.floor(teamCount / groupCount);
      const rem = teamCount % groupCount;
      let total = 0;
      for(let i = 0; i < groupCount; i++){
        const size = base + (i < rem ? 1 : 0);
        total += size * (size - 1) / 2;
      }
      return total;
    }

