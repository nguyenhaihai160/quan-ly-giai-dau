    function attachLiveStream(stream){
      const video = document.getElementById('liveCameraPreview');
      if(!video) return;
      video.srcObject = stream;
      video.muted = true;
      video.play().catch(() => {});
    }

    function stopStream(stream){
      if(!stream) return;
      stream.getTracks().forEach(track => track.stop());
    }

    function disconnectLiveCamera(showStatus = true){
      if(liveReplayState.isRecording) stopReplayCapture();
      stopStream(liveMediaState.stream);
      liveMediaState.stream = null;
      liveMediaState.currentDeviceId = '';
      liveMediaState.usingScreen = false;
      const video = document.getElementById('liveCameraPreview');
      if(video) video.srcObject = null;
      if(showStatus) updateLiveCameraStatus('Camera chưa kết nối.', 'idle');
      refreshCameraDeviceList();
      renderLiveReplayList();
    }

    async function connectLiveCamera(deviceId = ''){
      if(!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia){
        alert('Trình duyệt hiện tại không hỗ trợ kết nối camera.');
        return;
      }
      try{
        disconnectLiveCamera(false);
        const constraints = {
          video: deviceId ? { deviceId:{ exact:deviceId }, width:{ ideal:1280 }, height:{ ideal:720 } } : { width:{ ideal:1280 }, height:{ ideal:720 } },
          audio: true
        };
        const stream = await navigator.mediaDevices.getUserMedia(constraints);
        liveMediaState.stream = stream;
        liveMediaState.currentDeviceId = stream.getVideoTracks()[0]?.getSettings()?.deviceId || deviceId || '';
        liveMediaState.usingScreen = false;
        stream.getAudioTracks().forEach(track => track.enabled = !!liveMediaState.micEnabled);
        attachLiveStream(stream);
        await refreshCameraDeviceList();
        updateLiveCameraStatus('Đã kết nối camera cho trang live.', 'ok');
        renderLivestreamSummary();
      }catch(err){
        console.error(err);
        updateLiveCameraStatus('Không mở được camera. Hãy kiểm tra quyền truy cập.', 'warn');
      }
    }

    async function connectSelectedCamera(){
      const deviceId = document.getElementById('cameraDeviceSelect')?.value || '';
      await connectLiveCamera(deviceId);
    }

    async function switchLiveCamera(){
      await refreshCameraDeviceList();
      if(!liveMediaState.devices.length){
        alert('Không có camera để chuyển.');
        return;
      }
      const currentIndex = liveMediaState.devices.findIndex(device => device.deviceId === (liveMediaState.currentDeviceId || document.getElementById('cameraDeviceSelect')?.value));
      const nextIndex = currentIndex >= 0 ? (currentIndex + 1) % liveMediaState.devices.length : 0;
      const nextDeviceId = liveMediaState.devices[nextIndex].deviceId;
      const select = document.getElementById('cameraDeviceSelect');
      if(select) select.value = nextDeviceId;
      await connectLiveCamera(nextDeviceId);
    }

    function toggleLiveMic(){
      liveMediaState.micEnabled = !liveMediaState.micEnabled;
      if(liveMediaState.stream){
        liveMediaState.stream.getAudioTracks().forEach(track => track.enabled = !!liveMediaState.micEnabled);
      }
      updateLiveCameraStatus(liveMediaState.micEnabled ? 'Mic đang bật cho phiên live.' : 'Mic đã tắt cho phiên live.', liveMediaState.micEnabled ? 'ok' : 'warn');
