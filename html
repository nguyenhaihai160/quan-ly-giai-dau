<script id="live-v7-enhancements-script">
(function(){
  if(window.__liveV7Enhanced) return;
  window.__liveV7Enhanced = true;

  const MAX_SET_SLOTS = 5;

  function htmlEscape(str){
    return String(str ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function sanitizeScoreValueLoose(value){
    if(value === '' || value == null) return '';
    const n = parseInt(value, 10);
    return Number.isFinite(n) ? Math.max(0, n) : '';
  }

  function normalizeSetDetails(values){
    const src = Array.isArray(values) ? values.slice(0, MAX_SET_SLOTS) : [];
    while(src.length < MAX_SET_SLOTS) src.push('');
    return src.map(item => sanitizeScoreValueLoose(item));
  }

  function sanitizeFootballPeriodValue(value){
    return ['H1','HT','H2','ET','PEN','FT'].includes(value) ? value : 'H1';
  }

  function getFootballPeriodLabel(value){
    const map = { H1:'Hiệp 1', HT:'Giữa hiệp', H2:'Hiệp 2', ET:'Hiệp phụ', PEN:'Luân lưu', FT:'Kết thúc' };
    return map[sanitizeFootballPeriodValue(value)] || 'Hiệp 1';
  }

  function sanitizeScoreboardOrientationValue(value){
    return ['auto','vertical','horizontal'].includes(value) ? value : 'auto';
  }

  function resolveOrientation(layout, orientation){
    const dir = sanitizeScoreboardOrientationValue(orientation || 'auto');
    if(dir !== 'auto') return dir;
    return ['football','pickleball'].includes(layout) ? 'horizontal' : 'vertical';
  }

  function getSetSlotLabels(layout){
    if(layout === 'tabletennis') return ['Ván 1','Ván 2','Ván 3','Ván 4','Ván 5'];
    if(layout === 'football') return ['H1','H2','ET1','ET2','PEN'];
    return ['Set 1','Set 2','Set 3','Set 4','Set 5'];
  }

  function computeSetWins(detailsA, detailsB, fallbackA, fallbackB, layout){
    if(layout === 'football') return { a: sanitizeScoreValueLoose(fallbackA) || 0, b: sanitizeScoreValueLoose(fallbackB) || 0 };
    let winsA = 0, winsB = 0, hasAny = false;
    for(let i=0;i<MAX_SET_SLOTS;i++){
      const a = detailsA[i];
      const b = detailsB[i];
      if(a !== '' || b !== ''){
        hasAny = true;
        const av = Number(a || 0);
        const bv = Number(b || 0);
        if(av > bv) winsA += 1;
        else if(bv > av) winsB += 1;
      }
    }
    if(!hasAny){
      return { a: sanitizeScoreValueLoose(fallbackA) || 0, b: sanitizeScoreValueLoose(fallbackB) || 0 };
    }
    return { a: winsA, b: winsB };
  }

  function applyIdentityBadge(el, dataUrl, fallback){
    if(!el) return;
    if(dataUrl){
      el.classList.remove('is-empty');
      el.innerHTML = `<img src="${dataUrl}" alt="logo">`;
    }else{
      el.classList.add('is-empty');
      el.textContent = fallback || 'CLB';
    }
  }

  function applyFlagBadge(el, flag){
    if(!el) return;
    const value = String(flag || '').trim();
    if(value){
      el.classList.remove('is-empty');
      el.textContent = value;
    }else{
      el.classList.add('is-empty');
      el.textContent = '';
    }
  }

