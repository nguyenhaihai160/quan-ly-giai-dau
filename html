    function importExcel(){
      const file = document.getElementById('excelFile').files[0];
      if(!file){ alert('Vui lòng chọn file Excel.'); return; }

      const reader = new FileReader();
      reader.onload = function(e){
        try{
          const data = new Uint8Array(e.target.result);
          const wb = XLSX.read(data, { type:'array' });
          const sheet = wb.Sheets[wb.SheetNames[0]];
          const rows = XLSX.utils.sheet_to_json(sheet, { header:1 });
          let added = 0;

          rows.forEach((row, i) => {
            if(i === 0) return;
            const name = normalizeName(row[0]);
            if(!name) return;
            const seedCell = parseInt(row[1]);
            const exists = state.teams.some(t => t.name.toLowerCase() === name.toLowerCase());
            if(!exists){
              state.teams.push({
                id: Date.now() + '_' + Math.random().toString(36).slice(2,7),
                name,
                seed: (!isNaN(seedCell) && seedCell > 0) ? seedCell : state.teams.length + 1
              });
              added++;
            }
          });

          saveState();
          renderTeams();
          updateMetrics();
          alert(`Đã import ${added} đội.`);
        }catch(err){
          console.error(err);
          alert('File Excel không hợp lệ.');
        }
      };
      reader.readAsArrayBuffer(file);
    }

    function getSortedTeamsBySeed(){
      return [...state.teams].sort((a, b) => {
        const sa = parseInt(a.seed) || 999999;
        const sb = parseInt(b.seed) || 999999;
        if(sa !== sb) return sa - sb;
        return a.name.localeCompare(b.name, 'vi');
      });
    }

    /* KNOCKOUT TREE */
    function makeLeaf(player){ return { type:'leaf', player }; }
    function makeMatch(left, right){ return { type:'match', id:'M' + (++matchAutoId), left, right, round:0 }; }

    function buildExcelStyleTree(players, branchSide = 'top'){
      const n = players.length;
      if(n === 1) return makeLeaf(players[0]);
      if(n === 2) return makeMatch(makeLeaf(players[0]), makeLeaf(players[1]));

      let leftSize, rightSize;
      if(n % 2 === 0){
        leftSize = n / 2;
        rightSize = n / 2;
      }else if(branchSide === 'top'){
        leftSize = Math.floor(n / 2);
        rightSize = Math.ceil(n / 2);
      }else{
        leftSize = Math.ceil(n / 2);
        rightSize = Math.floor(n / 2);
      }

      const leftPlayers = players.slice(0, leftSize);
      const rightPlayers = players.slice(leftSize);

      return makeMatch(
        buildExcelStyleTree(leftPlayers, 'top'),
        buildExcelStyleTree(rightPlayers, 'bottom')
      );
    }

    function assignRounds(node){
      if(!node) return 0;
      if(node.type === 'leaf') return 0;
      const leftRound = assignRounds(node.left);
      const rightRound = assignRounds(node.right);
      node.round = Math.max(leftRound, rightRound) + 1;
      return node.round;
    }

    function collectMatchesByRound(node, bucket = {}){
      if(!node || node.type === 'leaf') return bucket;
      collectMatchesByRound(node.left, bucket);
      collectMatchesByRound(node.right, bucket);
      if(!bucket[node.round]) bucket[node.round] = [];
      bucket[node.round].push(node);
      return bucket;
    }

    function collectAllMatches(node, arr = []){
      if(!node || node.type === 'leaf') return arr;
      collectAllMatches(node.left, arr);
      collectAllMatches(node.right, arr);
      arr.push(node);
      return arr;
    }

    function findMatchNode(node, id){
      if(!node || node.type === 'leaf') return null;
      if(node.id === id) return node;
      return findMatchNode(node.left, id) || findMatchNode(node.right, id);
    }

    function getResultForMatch(matchId){ return state.results[`ko_${matchId}`]; }

    function clearAncestorResults(node, targetId){
      if(!node || node.type === 'leaf') return false;
      if(node.id === targetId) return true;
      const foundLeft = clearAncestorResults(node.left, targetId);
      const foundRight = clearAncestorResults(node.right, targetId);
      if(foundLeft || foundRight){
        delete state.results[`ko_${node.id}`];
        return true;
      }
      return false;
    }

    function resolveWinner(node){
      if(!node) return null;
      if(node.type === 'leaf') return node.player || null;
      const leftWinner = resolveWinner(node.left);
      const rightWinner = resolveWinner(node.right);

      if(leftWinner && !rightWinner) return leftWinner;
      if(rightWinner && !leftWinner) return rightWinner;
      if(!leftWinner || !rightWinner) return null;

      const rs = getResultForMatch(node.id);
      if(!rs) return null;
      if(!Number.isFinite(rs.a) || !Number.isFinite(rs.b)) return null;
      if(rs.a === rs.b) return null;
      return rs.a > rs.b ? leftWinner : rightWinner;
    }

    function isSideReady(node){
      if(!node) return false;
      if(node.type === 'leaf') return !!node.player;
      return !!resolveWinner(node);
    }

    function countRealPlayers(node){
      if(!node) return 0;
      if(node.type === 'leaf') return node.player ? 1 : 0;
      return countRealPlayers(node.left) + countRealPlayers(node.right);
    }

    function nextPowerOfTwo(n){
      let p = 1;
      while(p < n) p *= 2;
      return p;
    }

    function generateSeedOrder(size){
      let order = [1, 2];
      while(order.length < size){
        const nextSize = order.length * 2;
        const next = [];
        order.forEach(seed => {
          next.push(seed);
          next.push(nextSize + 1 - seed);
        });
        order = next;
      }
      return order;
    }

    function buildPriorityByeTree(players){
      if(!players?.length) return null;

      const normalizedSize = nextPowerOfTwo(players.length);
      const byeCount = normalizedSize - players.length;
      const slots = [];

      players.forEach((player, index) => {
        slots.push(makeLeaf({ ...player }));
        if(index < byeCount) slots.push(makeLeaf(null));
      });

      function buildFromSlots(items){
        if(items.length === 1) return items[0];

        const nextRound = [];
        for(let i = 0; i < items.length; i += 2){
          const left = items[i] || makeLeaf(null);
          const right = items[i + 1] || makeLeaf(null);
          nextRound.push(makeMatch(left, right));
        }
        return buildFromSlots(nextRound);
      }

      return buildFromSlots(slots);
    }

    function collectRoundNodesInOrder(node, targetRound, arr = []){
      if(!node || node.type === 'leaf') return arr;
      if(node.round === targetRound){
        arr.push(node);
        return arr;
      }
      collectRoundNodesInOrder(node.left, targetRound, arr);
      collectRoundNodesInOrder(node.right, targetRound, arr);
      return arr;
    }


    function countLeafSlots(node){
      if(!node) return 0;
      if(node.type === 'leaf') return 1;
      return countLeafSlots(node.left) + countLeafSlots(node.right);
    }

    function applyAdaptiveBracketSizing(root){
      if(!root) return;
      const stage = document.getElementById('bracketStage');
      const stageBody = document.querySelector('.bracket-body');
      const stageWidth = stageBody?.clientWidth || stage?.clientWidth || 1122;
      const rounds = Math.max(1, assignRounds(root));
      const leafSlots = Math.max(2, countLeafSlots(root));
      const leftPad = 22;
      const championWidth = 220;
      const matchW = Math.max(176, Math.min(228, Math.floor((stageWidth - leftPad - championWidth - (rounds - 1) * 34) / Math.max(rounds,1))));
      const colGap = Math.max(26, Math.min(48, Math.floor((stageWidth - leftPad - championWidth - rounds * matchW) / Math.max(rounds,1))));
      const leafStep = leafSlots >= 12 ? 74 : leafSlots >= 8 ? 84 : 94;
      const matchH = Math.max(68, Math.min(82, leafStep - 8));
      const headerH = Math.max(22, Math.min(26, Math.round(matchH * 0.31)));
      const rowH = Math.max(20, Math.floor((matchH - headerH) / 2));
      const pairGap = Math.max(8, leafStep - matchH);
      const rootStyles = document.documentElement.style;
      rootStyles.setProperty('--matchW', `${matchW}px`);
      rootStyles.setProperty('--matchH', `${matchH}px`);
      rootStyles.setProperty('--matchHeaderH', `${headerH}px`);
      rootStyles.setProperty('--matchRowH', `${rowH}px`);
      rootStyles.setProperty('--colGap', `${colGap}px`);
      rootStyles.setProperty('--pairGap', `${pairGap}px`);
      rootStyles.setProperty('--topPad', '78px');
      rootStyles.setProperty('--leftPad', `${leftPad}px`);
    }

    function computeTreeLayout(root){
      if(!root) return null;
      const styles = getComputedStyle(document.documentElement);
      const colGap = parseInt(styles.getPropertyValue('--colGap'));
      const pairGap = parseInt(styles.getPropertyValue('--pairGap'));
      const matchW = parseInt(styles.getPropertyValue('--matchW'));
      const matchH = parseInt(styles.getPropertyValue('--matchH'));
      const topPad = parseInt(styles.getPropertyValue('--topPad'));
      const leftPad = parseInt(styles.getPropertyValue('--leftPad'));
      const positions = {};
      const leafStep = matchH + pairGap;
      let leafIndex = 0;

      function walk(node){
        if(!node) return null;
        if(node.type === 'leaf'){
          const y = leafIndex * leafStep + matchH / 2;
          leafIndex++;
          return y;
        }

        const leftY = walk(node.left);
        const rightY = walk(node.right);
        const y = leftY == null ? rightY : rightY == null ? leftY : (leftY + rightY) / 2;

        positions[node.id] = {
          x: leftPad + (node.round - 1) * (matchW + colGap),
          y
        };

        return y;
      }

      const totalRounds = assignRounds(root);
      const rootY = walk(root);
      const allMatches = collectAllMatches(root, []);
      const roundMap = collectMatchesByRound(root, {});
      const roundNumbers = Object.keys(roundMap).map(Number).sort((a, b) => a - b);
      const championX = leftPad + totalRounds * (matchW + colGap);
      const championY = rootY;
      const usedLeaves = Math.max(leafIndex, 1);
      const height = topPad + Math.max((usedLeaves - 1) * leafStep + matchH + 170, 320);
      const width = championX + 290;

      return { positions, allMatches, roundMap, roundNumbers, totalRounds, width, height, championX, championY };
    }

    function getDisplayCodeMap(layout){
      const ordered = [...layout.allMatches]
        .filter(node => countRealPlayers(node.left) > 0 && countRealPlayers(node.right) > 0)
        .sort((a, b) => {
          if(a.round !== b.round) return a.round - b.round;
          return layout.positions[a.id].y - layout.positions[b.id].y;
        });
      const map = {};
      ordered.forEach((node, index) => { map[node.id] = String(index + 1).padStart(2, '0'); });
      return map;
    }

    function getMatchScoreText(matchId){
      const rs = getResultForMatch(matchId);
      if(rs && Number.isFinite(rs.a) && Number.isFinite(rs.b)){
        return `${rs.a} - ${rs.b}`;
      }
      return '---';
    }


    function getLoserOfMatch(node){
      if(!node || node.type === 'leaf') return null;
      const leftWinner = resolveWinner(node.left);
      const rightWinner = resolveWinner(node.right);
      if(!leftWinner || !rightWinner) return null;
      const rs = getResultForMatch(node.id);
      if(!rs || !Number.isFinite(rs.a) || !Number.isFinite(rs.b) || rs.a === rs.b) return null;
      return rs.a > rs.b ? rightWinner : leftWinner;
    }

    function getThirdPlaceContext(){
      if(!state.knockoutTree || !state.options?.includeThirdPlace) return null;
      assignRounds(state.knockoutTree);
      const totalRounds = state.knockoutTree.round || 0;
      if(totalRounds < 2) return null;
      const semis = collectRoundNodesInOrder(state.knockoutTree, totalRounds - 1, []).filter(Boolean);
      if(semis.length !== 2) return null;
      const loserA = getLoserOfMatch(semis[0]);
      const loserB = getLoserOfMatch(semis[1]);
      const matchId = `TP_${semis[0].id}_${semis[1].id}`;
      return { totalRounds, semis, loserA, loserB, matchId };
    }

    function getTeamFairPlayPenalty(team){
      const yellow = Number(team?.yellowCards) || 0;
      const red = Number(team?.redCards) || 0;
      return yellow + red * 2;
    }

    function getSortedGroupStandings(g){
      return [...(state.groups[g] || [])].sort((a, b) => {
        if(b.points !== a.points) return b.points - a.points;
        const diffA = a.gf - a.ga;
        const diffB = b.gf - b.ga;
        if(diffB !== diffA) return diffB - diffA;
        const fairA = getTeamFairPlayPenalty(a);
        const fairB = getTeamFairPlayPenalty(b);
        if(fairA !== fairB) return fairA - fairB;
        if((a.redCards || 0) !== (b.redCards || 0)) return (a.redCards || 0) - (b.redCards || 0);
        if((a.yellowCards || 0) !== (b.yellowCards || 0)) return (a.yellowCards || 0) - (b.yellowCards || 0);
        if(b.gf !== a.gf) return b.gf - a.gf;
        return (a.seed || 999) - (b.seed || 999);
      });
    }

    function buildKnockoutFinalRows(){
      if(!state.knockoutTree) return [];
      assignRounds(state.knockoutTree);
      const totalRounds = state.knockoutTree.round || 0;
      const rows = [];
      const seen = new Set();

      function pushRow(rank, title, team, note){
        if(!team || !team.id || seen.has(team.id)) return;
        seen.add(team.id);
        rows.push({ rank, title, teamName: team.name, note });
      }

      const champion = resolveWinner(state.knockoutTree);
      if(champion) pushRow(1, 'Vô địch', champion, 'Thắng trận chung kết');

      const runnerUp = getLoserOfMatch(state.knockoutTree);
      if(runnerUp) pushRow(2, 'Á quân', runnerUp, 'Thua trận chung kết');

      const thirdPlaceContext = getThirdPlaceContext();
      let stopRound = totalRounds - 1;

      if(thirdPlaceContext){
        const tpRs = getResultForMatch(thirdPlaceContext.matchId);
        const { loserA, loserB } = thirdPlaceContext;
        stopRound = totalRounds - 2;

        if(loserA && loserB && tpRs && Number.isFinite(tpRs.a) && Number.isFinite(tpRs.b) && tpRs.a !== tpRs.b){
          const third = tpRs.a > tpRs.b ? loserA : loserB;
          const fourth = tpRs.a > tpRs.b ? loserB : loserA;
          pushRow(3, 'Hạng 3', third, 'Thắng trận tranh hạng ba');
          pushRow(4, 'Hạng 4', fourth, 'Thua trận tranh hạng ba');
        }else{
          if(loserA) pushRow(3, 'Chờ tranh hạng 3', loserA, 'Chờ kết quả trận tranh hạng ba');
          if(loserB) pushRow(3, 'Chờ tranh hạng 3', loserB, 'Chờ kết quả trận tranh hạng ba');
        }
      }

      for(let roundNo = stopRound; roundNo >= 1; roundNo--){
        const roundNodes = collectRoundNodesInOrder(state.knockoutTree, roundNo, []);
        const rank = roundNo === totalRounds - 1 ? 3 : (Math.pow(2, totalRounds - roundNo) + 1);
        const phase = getPhaseNameByIndex(roundNo - 1, totalRounds);
        roundNodes.forEach(node => {
          const loser = getLoserOfMatch(node);
          if(loser){
            pushRow(rank, rank === 3 ? 'Đồng hạng 3' : `Đồng hạng ${rank}`, loser, `Dừng ở ${phase}`);
          }
        });
      }

      return rows.sort((a, b) => a.rank - b.rank || a.teamName.localeCompare(b.teamName, 'vi'));
    }

    function renderFinalStandings(targetId = 'finalStandings'){
      const el = document.getElementById(targetId);
      if(!el) return;

      if(state.format === 'groups'){
        if(!state.groups || !state.groups.length){
          el.innerHTML = `<div class="final-empty">Chưa có dữ liệu vòng bảng để xếp hạng.</div>`;
          return;
        }

        let html = '<div class="table-wrap"><table class="final-standings-table"><thead><tr><th>Hạng</th><th>Bảng</th><th>Đội / VĐV</th><th>Điểm</th><th>HS</th></tr></thead><tbody>';
        state.groups.forEach((group, g) => {
          html += `<tr class="group-row"><td colspan="5">BẢNG ${String.fromCharCode(65 + g)}</td></tr>`;
          getSortedGroupStandings(g).forEach((team, i) => {
            html += `
              <tr>
                <td><span class="rank-pill ${i === 0 ? 'rank-1' : i === 1 ? 'rank-2' : i === 2 ? 'rank-3' : 'rank-other'}">${i + 1}</span></td>
                <td>${String.fromCharCode(65 + g)}</td>
                <td>${escapeHtml(team.name)}</td>
                <td>${team.points}</td>
                <td>${team.gf - team.ga}</td>
              </tr>`;
          });
        });
        html += '</tbody></table></div><div class="ranking-note">Thể thức vòng bảng sẽ xếp hạng theo điểm, hiệu số rồi đến seed.</div>';
        el.innerHTML = html;
        return;
      }

      const rows = buildKnockoutFinalRows();
      const isDone = !!resolveWinner(state.knockoutTree);
      if(!rows.length){
        el.innerHTML = `<div class="final-empty">Chưa có đủ kết quả để xếp hạng. Hãy nhập tỉ số ở phần Lịch thi đấu.</div>`;
        return;
      }

      let html = `
        <div class="table-wrap">
          <table class="final-standings-table">
            <thead>
              <tr>
                <th>Hạng</th>
                <th>Danh hiệu</th>
                <th>Đội / VĐV</th>
                <th>Ghi chú</th>
              </tr>
            </thead>
            <tbody>`;

      rows.forEach(row => {
        const rankClass = row.rank === 1 ? 'rank-1' : row.rank === 2 ? 'rank-2' : row.rank === 3 ? 'rank-3' : 'rank-other';
        html += `
          <tr>
            <td><span class="rank-pill ${rankClass}">${row.rank}</span></td>
            <td>${escapeHtml(row.title)}</td>
            <td>${escapeHtml(row.teamName)}</td>
            <td>${escapeHtml(row.note)}</td>
          </tr>`;
      });

      html += `</tbody></table></div>
      <div class="ranking-note">${isDone ? 'Bảng xếp hạng đã chốt theo kết quả cuối cùng. Các đội thua cùng vòng sẽ đồng hạng nếu không có trận tranh hạng.' : 'Bảng xếp hạng đang cập nhật theo các tỉ số đã lưu. Khi giải kết thúc, bảng này sẽ tự chốt 1, 2, 3 và các đồng hạng tiếp theo.'}</div>`;
      el.innerHTML = html;
    }

    function renderAllStandings(){
      renderFinalStandings('finalStandings');
      renderFinalStandings('finalStandingsMini');
    }

    function getPrettyNodeLabel(node, codeMap = {}){
      if(!node) return 'Chờ xác định';
      if(node.type === 'leaf') return node.player ? node.player.name : 'BYE';
      const winner = resolveWinner(node);
      return winner ? winner.name : `Thắng ${codeMap[node.id] || node.id}`;
    }

    function matchNeedsManualScore(node){
      if(!node || node.type === 'leaf') return false;
      const leftWinner = resolveWinner(node.left);
      const rightWinner = resolveWinner(node.right);
      return !!leftWinner && !!rightWinner;
    }

    function getAutoWinnerSide(node){
      if(!node || node.type === 'leaf') return 0;
      const rs = getResultForMatch(node.id);
      if(rs && Number.isFinite(rs.a) && Number.isFinite(rs.b) && rs.a !== rs.b){
        return rs.a > rs.b ? 1 : 2;
      }
      const leftWinner = resolveWinner(node.left);
      const rightWinner = resolveWinner(node.right);
      if(leftWinner && !rightWinner) return 1;
      if(rightWinner && !leftWinner) return 2;
      return 0;
    }

    function getPhaseNameByIndex(index, total){
      const remain = total - index;
      if(remain === 1) return 'Chung kết';
      if(remain === 2) return 'Bán kết';
      if(remain === 3) return 'Tứ kết';
      if(remain === 4) return 'R16';
      if(remain === 5) return 'R32';
      if(remain === 6) return 'R64';
      if(remain === 7) return 'R128';
      return `Vòng ${index + 1}`;
    }

    function createTournament(goTeamsAfterCreate = true){
      syncInfoDataFromMain();
      if(state.teams.length < 2){ alert('Cần ít nhất 2 đội để tạo giải.'); return; }

      state.results = {};
      state.schedule = [];
      state.knockoutTree = null;
      state.groups = [];

      if(state.format === 'knockout') createKnockout();
      else createGroups();

      saveState();
      updateTournamentInfoBar();
      updateMetrics();
      generateSchedule();
      switchTab(goTeamsAfterCreate ? 'tabTeams' : (state.format === 'knockout' ? 'tabBracket' : 'tabSchedule'));
    }

    function createKnockout(){
      const players = getSortedTeamsBySeed().map(t => ({ ...t }));
      if(players.length < 2){ alert('Cần ít nhất 2 đội.'); return; }
      matchAutoId = 0;
      state.knockoutTree = buildPriorityByeTree(players);
      assignRounds(state.knockoutTree);
      renderBracket();
      renderGroupAreaEmpty();
      saveState();
    }

    function renderBracket(){
      const canvas = document.getElementById('bracketCanvas');
      const svg = document.getElementById('bracketSvg');
      const titleBadge = document.getElementById('bracketTitleBadge');
      canvas.innerHTML = '';
      canvas.appendChild(svg);
      svg.innerHTML = '';
      titleBadge.textContent = state.format === 'knockout' ? 'BẢNG ĐẤU & KẾT QUẢ' : 'VÒNG BẢNG';

      if(state.format !== 'knockout' || !state.knockoutTree){
        canvas.innerHTML = `<div class="empty">Chưa có nhánh loại trực tiếp.</div>`;
        canvas.style.height = '260px';
        canvas.style.width = '100%';
        return;
      }

      applyAdaptiveBracketSizing(state.knockoutTree);
      const layout = computeTreeLayout(state.knockoutTree);
      const codeMap = getDisplayCodeMap(layout);
      const styles = getComputedStyle(document.documentElement);
      const leftPad = parseInt(styles.getPropertyValue('--leftPad'));
      const matchW = parseInt(styles.getPropertyValue('--matchW'));
      const colGap = parseInt(styles.getPropertyValue('--colGap'));
      const topPad = parseInt(styles.getPropertyValue('--topPad'));
      const matchH = parseInt(styles.getPropertyValue('--matchH'));

      canvas.style.width = layout.width + 'px';
      canvas.style.height = layout.height + 'px';

      layout.roundNumbers.forEach((roundNo, idx) => {
        const title = document.createElement('div');
        title.className = 'round-header';
        title.style.left = (leftPad + idx * (matchW + colGap)) + 'px';
        title.style.width = Math.min(matchW, 176) + 'px';
        title.textContent = getPhaseNameByIndex(idx, layout.roundNumbers.length);
        canvas.appendChild(title);
      });

      layout.allMatches.forEach(node => {
        const pos = layout.positions[node.id];
        const autoWinnerSide = getAutoWinnerSide(node);
        let topClass = 'pending';
        let bottomClass = 'pending';

        if(autoWinnerSide === 1){
          topClass = 'win';
          bottomClass = 'lose';
        }else if(autoWinnerSide === 2){
          topClass = 'lose';
          bottomClass = 'win';
        }

        const box = document.createElement('div');
        box.className = 'bracket-match';
        box.dataset.matchId = node.id;
        box.style.left = pos.x + 'px';
        box.style.top = (topPad + pos.y - (matchH / 2)) + 'px';
        box.innerHTML = `
          <div class="match-card-box">
            <div class="match-anchor anchor-in-top"></div>
            <div class="match-anchor anchor-in-bottom"></div>
            <div class="match-anchor anchor-out"></div>
            <div class="match-topbar">
              <div class="match-code-box">MÃ ${codeMap[node.id]}</div>
              <div class="match-score-box">TỶ SỐ ${escapeHtml(getMatchScoreText(node.id))}</div>
            </div>
            <div class="match-row">
              <div class="player-row ${topClass}">${escapeHtml(getPrettyNodeLabel(node.left, codeMap))}</div>
            </div>
            <div class="match-row">
              <div class="player-row ${bottomClass}">${escapeHtml(getPrettyNodeLabel(node.right, codeMap))}</div>
            </div>
          </div>
        `;
        canvas.appendChild(box);
      });

      const champion = resolveWinner(state.knockoutTree);
      const championBox = document.createElement('div');
      championBox.className = 'champion-box';
      championBox.style.left = layout.championX + 'px';
      championBox.style.top = (topPad + layout.championY - 60) + 'px';
      championBox.innerHTML = `
        <div class="champion-anchor"></div>
        <div class="champion-icon">🏆</div>
        <div class="champion-name">${escapeHtml(champion ? champion.name : 'Chưa xác định')}</div>
      `;
      canvas.appendChild(championBox);

      const championTitle = document.createElement('div');
      championTitle.className = 'round-header';
      championTitle.style.left = layout.championX + 'px';
      championTitle.style.width = '150px';
      championTitle.textContent = 'Vô địch';
      canvas.appendChild(championTitle);

      requestAnimationFrame(drawBracketLines);
    }

    function drawBracketLines(){
      if(state.format !== 'knockout' || !state.knockoutTree) return;
      const canvas = document.getElementById('bracketCanvas');
      const svg = document.getElementById('bracketSvg');
      applyAdaptiveBracketSizing(state.knockoutTree);
      const layout = computeTreeLayout(state.knockoutTree);
      if(!layout) return;

      svg.innerHTML = '';
      svg.setAttribute('width', layout.width);
      svg.setAttribute('height', layout.height);
      svg.setAttribute('viewBox', `0 0 ${layout.width} ${layout.height}`);
      svg.style.width = layout.width + 'px';
      svg.style.height = layout.height + 'px';
      svg.style.left = '0px';
      svg.style.top = '0px';

      function getPoint(anchorEl){
        if(!anchorEl) return null;
        const canvasRect = canvas.getBoundingClientRect();
        const rect = anchorEl.getBoundingClientRect();
        return {
          x: rect.left - canvasRect.left + rect.width / 2,
          y: rect.top - canvasRect.top + rect.height / 2
        };
      }

      function getMatchAnchors(matchId){
        const card = canvas.querySelector(`.bracket-match[data-match-id="${matchId}"] .match-card-box`);
        if(!card) return null;
        return {
          inputTop: getPoint(card.querySelector('.anchor-in-top')),
          inputBottom: getPoint(card.querySelector('.anchor-in-bottom')),
          output: getPoint(card.querySelector('.anchor-out'))
        };
      }

      function getChampionAnchor(){
        return getPoint(canvas.querySelector('.champion-box .champion-anchor'));
      }

      function appendPath(d){
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('class', 'svg-path');
        path.setAttribute('d', d);
        svg.appendChild(path);
      }

      function drawHorizontal(x1, y, x2){
        if(x1 == null || x2 == null || y == null || Math.abs(x2 - x1) < 1) return;
        appendPath(`M ${x1} ${y} L ${x2} ${y}`);
      }

      function drawVertical(x, y1, y2){
        if(x == null || y1 == null || y2 == null || Math.abs(y2 - y1) < 1) return;
        appendPath(`M ${x} ${y1} L ${x} ${y2}`);
      }

      function connectChildToParent(childAnchor, parentAnchor){
        if(!childAnchor || !parentAnchor) return;
        const span = Math.max(34, Math.min(72, (parentAnchor.x - childAnchor.x) * 0.48));
        const trunkX = Math.min(parentAnchor.x - 24, childAnchor.x + span);
        drawHorizontal(childAnchor.x, childAnchor.y, trunkX);
        drawVertical(trunkX, childAnchor.y, parentAnchor.y);
        drawHorizontal(trunkX, parentAnchor.y, parentAnchor.x);
      }

      layout.allMatches.forEach(parent => {
        const parentAnchors = getMatchAnchors(parent.id);
        if(!parentAnchors) return;

        if(parent.left && parent.left.type === 'match'){
          const leftChild = getMatchAnchors(parent.left.id);
          connectChildToParent(leftChild?.output, parentAnchors.inputTop);
        }

        if(parent.right && parent.right.type === 'match'){
          const rightChild = getMatchAnchors(parent.right.id);
          connectChildToParent(rightChild?.output, parentAnchors.inputBottom);
        }
      });

      const rootAnchors = getMatchAnchors(state.knockoutTree.id);
      const championAnchor = getChampionAnchor();
      if(rootAnchors && championAnchor){
        connectChildToParent(rootAnchors.output, championAnchor);
      }
    }

