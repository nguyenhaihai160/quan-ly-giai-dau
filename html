      if(typeof item.data.tournamentInfo.description !== 'string') item.data.tournamentInfo.description = item.note || '';
      item.data.viewSettings.startTime = item.data.viewSettings.startTime || '';
      item.data.viewSettings.scheduleFromDate = item.data.viewSettings.scheduleFromDate || '';
      item.data.viewSettings.scheduleToDate = item.data.viewSettings.scheduleToDate || item.data.viewSettings.scheduleFromDate || '';
