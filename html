    function randomizeSeeds(){
      if(state.teams.length < 2){
        alert('Cần ít nhất 2 đội để bốc thăm seed.');
        return;
      }
      const items = [...state.teams];
      for(let i = items.length - 1; i > 0; i--){
        const j = Math.floor(Math.random() * (i + 1));
        [items[i], items[j]] = [items[j], items[i]];
      }
      items.forEach((team, index) => team.seed = index + 1);
      state.teams = items;
      saveState();
      renderTeams();
      updateMetrics();
      alert('Đã bốc thăm seed ngẫu nhiên cho toàn bộ VĐV / đội.');
    }

