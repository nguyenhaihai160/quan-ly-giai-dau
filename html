    }

    function renderStatusControl(match, statusKey){
      const manualStatus = state.matchStatuses?.[statusKey] || '';
      const options = [
        { value:'', label:'Tự động theo giờ' },
        { value:'scheduled', label:'Sắp đấu' },
        { value:'live', label:'Đang đấu' },
        { value:'paused', label:'Tạm dừng' },
        { value:'postponed', label:'Tạm hoãn' },
        { value:'finished', label:'Kết thúc' }
      ];
      return `
        <div class=\"status-select-wrap\">
          <div class=\"status-select-title\">Trạng thái trận</div>
          <select class=\"match-status-dropdown\" onchange=\"setMatchOperationalStatus('${escapeJsString(statusKey)}', this.value)\">
            ${options.map(item => `<option value=\"${item.value}\" ${item.value === manualStatus ? 'selected' : ''}>${item.label}</option>`).join('')}
          </select>
        </div>`;
    }

    function timeStringToMinutes(value, fallback = 480){
      const m = String(value || '').match(/^(\d{2}):(\d{2})$/);
      if(!m) return fallback;
      return parseInt(m[1], 10) * 60 + parseInt(m[2], 10);
    }

    function combineDateAndTime(dateStr, timeStr){
      return new Date(`${dateStr}T${timeStr}`);
    }

    function syncLegacyStartTime(){
      const fromDate = document.getElementById('scheduleFromDate')?.value;
      const startTime = document.getElementById('dailyStartTime')?.value || '08:00';
      const legacy = document.getElementById('startTime');
      if(legacy && fromDate){
        legacy.value = `${fromDate}T${startTime}`;
      }
    }

    function scheduleConfigFromUI(){
      const now = new Date();
      const fallbackDate = formatDateOnly(now);
      const fromDate = document.getElementById('scheduleFromDate')?.value || fallbackDate;
      const toDate = document.getElementById('scheduleToDate')?.value || fromDate;
      const dayStart = document.getElementById('dailyStartTime')?.value || '08:00';
      const dayEnd = document.getElementById('dailyEndTime')?.value || '20:00';
      return { fromDate, toDate, dayStart, dayEnd };
    }

    function scheduleMatchesInRange(matches, duration, breakMin, courts){
      const config = scheduleConfigFromUI();
      if(config.toDate < config.fromDate){
        throw new Error('Ngày kết thúc phải lớn hơn hoặc bằng ngày bắt đầu.');
      }
      const startMin = timeStringToMinutes(config.dayStart, 480);
      const endMin = timeStringToMinutes(config.dayEnd, 1200);
      if(endMin <= startMin){
        throw new Error('Giờ kết thúc ngày phải lớn hơn giờ bắt đầu ngày.');
      }

      const nextDayStart = dateObj => {
        const next = new Date(dateObj);
        next.setDate(next.getDate() + 1);
        return combineDateAndTime(formatDateOnly(next), config.dayStart);
      };

      let cursor = combineDateAndTime(config.fromDate, config.dayStart);
      const schedule = [];
      let idx = 0;

      while(idx < matches.length){
        const dayKey = formatDateOnly(cursor);
        if(dayKey > config.toDate){
          throw new Error('Khoảng ngày thi đấu hiện tại không đủ để xếp hết lịch. Hãy tăng số sân, giảm thời lượng hoặc nới ngày kết thúc.');
        }

        let slotStart = new Date(cursor);
        const currentMinutes = slotStart.getHours() * 60 + slotStart.getMinutes();
        if(currentMinutes < startMin){
          slotStart = combineDateAndTime(dayKey, config.dayStart);
        }

        const slotEnd = addMinutes(slotStart, duration);
        const slotEndMinutes = slotEnd.getHours() * 60 + slotEnd.getMinutes();

        if(slotEndMinutes > endMin || formatDateOnly(slotEnd) !== dayKey){
          cursor = nextDayStart(slotStart);
          continue;
        }

        const batch = matches.slice(idx, idx + courts);
        batch.forEach((m, courtIndex) => {
          schedule.push({
            ...m,
            start: new Date(slotStart),
            end: new Date(slotEnd),
            court: `Sân ${courtIndex + 1}`,
            courtNo: courtIndex + 1
          });
        });

        idx += batch.length;
        cursor = addMinutes(slotEnd, breakMin);
        const cursorMinutes = cursor.getHours() * 60 + cursor.getMinutes();
        if(cursorMinutes >= endMin || formatDateOnly(cursor) !== dayKey){
          cursor = nextDayStart(slotStart);
        }
      }

      syncLegacyStartTime();
      return schedule;
    }

    function scheduleRoundMatchesSequentially(groupedRounds, duration, breakMin, courts){
      const config = scheduleConfigFromUI();
      if(config.toDate < config.fromDate){
        throw new Error('Ngày kết thúc phải lớn hơn hoặc bằng ngày bắt đầu.');
      }
      const startMin = timeStringToMinutes(config.dayStart, 480);
      const endMin = timeStringToMinutes(config.dayEnd, 1200);
      if(endMin <= startMin){
        throw new Error('Giờ kết thúc ngày phải lớn hơn giờ bắt đầu ngày.');
      }
      const nextDayStart = dateObj => {
        const next = new Date(dateObj);
        next.setDate(next.getDate() + 1);
        return combineDateAndTime(formatDateOnly(next), config.dayStart);
      };
      let cursor = combineDateAndTime(config.fromDate, config.dayStart);
      const schedule = [];
      groupedRounds.forEach(roundMatches => {
        let idx = 0;
        while(idx < roundMatches.length){
          const dayKey = formatDateOnly(cursor);
          if(dayKey > config.toDate){
            throw new Error('Khoảng ngày thi đấu hiện tại không đủ để xếp hết lịch. Hãy tăng số sân, giảm thời lượng hoặc nới ngày kết thúc.');
          }
          let slotStart = new Date(cursor);
          const currentMinutes = slotStart.getHours() * 60 + slotStart.getMinutes();
          if(currentMinutes < startMin) slotStart = combineDateAndTime(dayKey, config.dayStart);
          const slotEnd = addMinutes(slotStart, duration);
          const slotEndMinutes = slotEnd.getHours() * 60 + slotEnd.getMinutes();
          if(slotEndMinutes > endMin || formatDateOnly(slotEnd) !== dayKey){
            cursor = nextDayStart(slotStart);
            continue;
          }
          const batch = roundMatches.slice(idx, idx + courts);
          batch.forEach((m, courtIndex) => {
            schedule.push({ ...m, start:new Date(slotStart), end:new Date(slotEnd), court:`Sân ${courtIndex + 1}`, courtNo:courtIndex + 1 });
          });
          idx += batch.length;
          cursor = addMinutes(slotEnd, breakMin);
          const cursorMinutes = cursor.getHours() * 60 + cursor.getMinutes();
          if(cursorMinutes >= endMin || formatDateOnly(cursor) !== dayKey){
            cursor = nextDayStart(slotStart);
          }
        }
      });
      return schedule;
    }


    function getCourtNumber(label){
      const m = String(label || '').match(/(\d+)/);
      return m ? parseInt(m[1], 10) : 1;
    }

    function hasNumericScore(a, b){
      return Number.isFinite(Number(a)) && Number.isFinite(Number(b));
    }

    function getScheduleMatchKey(match){
      if(match?.matchId) return `ko_${match.matchId}`;
      return `gr_${normalizeName(match?.phase || '')}__${normalizeName(match?.teamA || '')}__${normalizeName(match?.teamB || '')}`;
    }

    function makeDomSafeId(value){
      return String(value || '').replace(/[^a-zA-Z0-9_-]+/g, '_');
    }

    function escapeJsString(value){
      return String(value || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
    }

    function getStatusText(status){
      const map = {
        waiting:'Sắp đấu',
        pending:'Sắp đấu',
        scheduled:'Sắp đấu',
        live:'Đang đấu',
        paused:'Tạm dừng',
        postponed:'Tạm hoãn',
        overtime:'Quá giờ',
        finished:'Đã kết thúc',
        bye:'BYE / Tự động'
      };
      return map[status] || 'Sắp đấu';
    }

    function findGroupResultByMatch(match){
      if(match?.groupIndex != null && match?.teamAIndex != null && match?.teamBIndex != null){
        return state.results[`group_${match.groupIndex}_${match.teamAIndex}_${match.teamBIndex}`] || null;
      }
      if(Array.isArray(state.groups)){
        for(let g = 0; g < state.groups.length; g++){
          const group = state.groups[g] || [];
          for(let i = 0; i < group.length; i++){
            for(let j = i + 1; j < group.length; j++){
              const A = normalizeName(group[i]?.name);
              const B = normalizeName(group[j]?.name);
              const mA = normalizeName(match?.teamA);
              const mB = normalizeName(match?.teamB);
              if((A === mA && B === mB) || (A === mB && B === mA)){
                return state.results[`group_${g}_${i}_${j}`] || null;
              }
            }
          }
        }
      }
      return null;
    }

    function normalizeAllMatchStatuses(){
      if(!state.matchStatuses) state.matchStatuses = {};
      const nextStatuses = {};
      const allowed = new Set(['scheduled','live','paused','postponed','finished','waiting','overtime','bye']);
      if(Array.isArray(state.schedule)){
        state.schedule.forEach(match => {
          const key = getScheduleMatchKey(match);
          if(match?.autoAdvance){
            nextStatuses[key] = 'bye';
            return;
          }
          const groupResult = findGroupResultByMatch(match);
          const hasSavedScore = hasNumericScore(match?.scoreA, match?.scoreB) || hasNumericScore(groupResult?.a, groupResult?.b);
          if(hasSavedScore){
            nextStatuses[key] = 'finished';
            return;
          }
          const existing = state.matchStatuses?.[key];
          if(allowed.has(existing) && existing !== 'bye'){
            nextStatuses[key] = existing;
          }
        });
      }
      state.matchStatuses = nextStatuses;
    }

    function getMatchStatus(match){
      if(match?.autoAdvance) return 'bye';
      const key = getScheduleMatchKey(match);
      const groupResult = findGroupResultByMatch(match);
      const hasSavedScore = hasNumericScore(match?.scoreA, match?.scoreB) || hasNumericScore(groupResult?.a, groupResult?.b);
      if(hasSavedScore) return 'finished';
      const manual = state.matchStatuses?.[key];
      if(manual) return manual === 'waiting' ? 'scheduled' : manual;
      return getAutoMatchStatusByTime(match);
    }

    function setMatchOperationalStatus(matchKey, value, silent = false){
      if(!matchKey) return;
      if(!state.matchStatuses) state.matchStatuses = {};
      if(value){
        state.matchStatuses[matchKey] = value;
      }else{
        delete state.matchStatuses[matchKey];
      }
      saveState();
      renderSchedule();
      renderLivestreamSummary();
      updateHomeDashboard();
      if(!silent && value){
        // intentionally quiet unless explicitly needed
      }
    }

    function updateMatchStatus(selectEl){
      const key = selectEl?.dataset?.matchKey;
      if(!key) return;
      setMatchOperationalStatus(key, selectEl?.value || '', true);
    }

    function updateScheduleDateTime(matchKey, domKey){
      if(!matchKey || !domKey || !Array.isArray(state.schedule)) return;
      const startInput = document.getElementById(`schedStart_${domKey}`);
      const endInput = document.getElementById(`schedEnd_${domKey}`);
      if(!startInput || !endInput) return;

      const match = state.schedule.find(item => getScheduleMatchKey(item) === matchKey);
      if(!match) return;

      const originalStart = new Date(match.start);
      const originalEnd = new Date(match.end);
      const durationMs = Math.max(1, originalEnd - originalStart);

      const nextStart = startInput.value ? new Date(startInput.value) : originalStart;
      const nextEnd = endInput.value ? new Date(endInput.value) : new Date(nextStart.getTime() + durationMs);

      if(Number.isNaN(nextStart.getTime()) || Number.isNaN(nextEnd.getTime())){
        alert('Vui lòng nhập ngày giờ hợp lệ.');
        return;
      }
      if(nextEnd <= nextStart){
        alert('Giờ kết thúc phải sau giờ bắt đầu.');
        return;
      }

      match.start = nextStart;
      match.end = nextEnd;
      saveState();
      renderSchedule();
    }

    function toInputDateTimeValue(date){
      const pad = n => String(n).padStart(2, '0');
      return `${date.getFullYear()}-${pad(date.getMonth()+1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
    }

    function addMinutes(date, minutes){
      return new Date(date.getTime() + minutes * 60000);
    }

    function formatLabelForDisplay(value, fallback = '-'){
      return value && String(value).trim() ? value : fallback;
    }

