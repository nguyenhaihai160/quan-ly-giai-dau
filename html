    function recalculateGroup(g){
      state.groups[g].forEach(t => {
        t.played = 0; t.points = 0; t.gf = 0; t.ga = 0; t.yellowCards = 0; t.redCards = 0;
      });

      for(let i = 0; i < state.groups[g].length; i++){
        for(let j = i + 1; j < state.groups[g].length; j++){
          const key = `group_${g}_${i}_${j}`;
          const rs = state.results[key];
          if(!rs) continue;
          const A = state.groups[g][i];
          const B = state.groups[g][j];
          const a = rs.a;
          const b = rs.b;
          const yellowA = Math.max(0, Number(rs.yellowA) || 0);
          const yellowB = Math.max(0, Number(rs.yellowB) || 0);
          const redA = Math.max(0, Number(rs.redA) || 0);
          const redB = Math.max(0, Number(rs.redB) || 0);
          A.played++; B.played++;
          A.gf += a; A.ga += b; A.yellowCards += yellowA; A.redCards += redA;
          B.gf += b; B.ga += a; B.yellowCards += yellowB; B.redCards += redB;
          if(a > b) A.points += 3;
          else if(b > a) B.points += 3;
          else { A.points += 1; B.points += 1; }
        }
      }

      renderGroupTable(g);
